@{
    ViewData["Title"] = "Vehicle Info";
}
<link href="/css/site.css" rel="stylesheet">
<link href="/Design/vendor/select2/dist/css/select2.min.css" rel="stylesheet" type="text/css">

<div class="container-fluid" id="container-wrapper" ng-app="ngApp" ng-controller="ngGridCtrl">
    <div class="d-sm-flex align-items-center justify-content-between mb-4 sm-breadcrumb">
        <h4 class="h3 mb-0 text-gray-600">
            @ViewData["Title"].ToString()
        </h4>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><button class="btn  btn-danger mb-1" ng-click="ClearForm()">Reset</button></li>
            <li class="breadcrumb-item"><button type="button" style="width: 100px;color:white;cursor:pointer" pe="button" ng-disabled="formMenuCategoryAdd.$invalid" name="btnSubmit" class="btn  btn-success mb-1" ng-click="SaveData(model)">{{buttonName}}</button></li>
        </ol>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <form name="formMenuCategoryAdd">
                <fieldset>
                    <legend style="width:140px">Vehicle Entry</legend>
                    <div class="row" style="margin:20px">
                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="COMPANY_ID">Company</label>
                                </div>
                                <div class="col-md-8">
                                    <select class="select2-single form-control" id="COMPANY_ID" ng-disabled="true"
                                            name="COMPANY_ID" ng-model="model.COMPANY_ID" style="width:100%" ng-change="LoadGeneratedAreaCode()">
                                        <option ng-repeat="item in Companies" ng-selected="item.COMPANY_ID == model.COMPANY_ID" value="{{item.COMPANY_ID}}">{{item.COMPANY_NAME}}</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="STATUS">Status</label>
                                </div>
                                <div class="col-md-8">
                                    <select class="form-control" id="STATUS"
                                            name="STATUS" ng-model="model.STATUS" style="width:100%">
                                        <option ng-repeat="item in Status" value="{{item.STATUS}}" ng-selected="item.STATUS == model.STATUS">{{item.STATUS}}</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="VEHICLE_NO">Vehicle No</label>
                                </div>
                                <div class="col-md-8">
                                    <input id="VEHICLE_NO" type="text" class="form-control" required
                                           name="VEHICLE_NO" ng-model="model.VEHICLE_NO">
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="UNIT_ID">Depot</label>
                                </div>
                                <div class="col-md-8">
                                    <select class=" form-control" id="UNIT_ID" ng-disabled="model.CUSTOMER_ID>0"
                                            name="UNIT_ID" ng-model="model.UNIT_ID" style="width:100%" required ng-change="changeUnitId()">

                                        <option ng-repeat="item in Units" value="{{item.UNIT_ID}}" ng-selected="item.UNIT_ID == model.UNIT_ID">{{item.UNIT_NAME}}</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-12 space-bottom">
                            <div class="row">
                                <div class="col-md-2">
                                    <label for="VEHICLE_DESCRIPTION">Description</label>
                                </div>
                                <div class="col-md-10">
                                    <input id="VEHICLE_DESCRIPTION" type="text" class="form-control"
                                           name="VEHICLE_DESCRIPTION" ng-model="model.VEHICLE_DESCRIPTION">
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="VEHICLE_TOTAL_VOLUME">Volume</label>
                                </div>
                                <div class="col-md-8">
                                    <input id="VEHICLE_TOTAL_VOLUME" type="number" min="0" class="form-control" ng-pattern={{NumberPattern}}
                                           name="VEHICLE_TOTAL_VOLUME" ng-model="model.VEHICLE_TOTAL_VOLUME">
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="VOLUME_UNIT">Volume Unit</label>
                                </div>

                                <div class="col-md-8">
                                    <select class="select2-single-Region form-control" id="VOLUME_UNIT"
                                            name="VOLUME_UNIT" ng-model="model.VOLUME_UNIT" style="width:100%">

                                        <option ng-repeat="item in UnitVolume" value="{{item.MEASURING_UNIT_ID}}">{{item.MEASURING_UNIT_NAME}} </option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="VEHICLE_TOTAL_WEIGHT">Weight</label>
                                </div>
                                <div class="col-md-8">
                                    <input id="VEHICLE_TOTAL_WEIGHT" type="number" min="0" class="form-control" ng-pattern={{NumberPattern}}
                                           name="VEHICLE_TOTAL_WEIGHT" ng-model="model.VEHICLE_TOTAL_WEIGHT">
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="WEIGHT_UNIT">Weight Unit</label>
                                </div>

                                <div class="col-md-8">
                                    <select class="select2-single-Region form-control" id="WEIGHT_UNIT"
                                            name="WEIGHT_UNIT" ng-model="model.WEIGHT_UNIT" style="width:100%">

                                        <option ng-repeat="item in UnitWeight" value="{{item.MEASURING_UNIT_ID}}">{{item.MEASURING_UNIT_NAME}} </option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="DRIVER_ID">Driver</label>
                                </div>

                                <div class="col-md-8">
                                    <select class="select2-single-Region form-control" id="DRIVER_ID"
                                            name="DRIVER_ID" ng-model="model.DRIVER_ID" style="width:100%" required>

                                        <option ng-repeat="item in Drivers" value="{{item.DRIVER_ID}}">{{item.DRIVER_NAME}} </option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="REMARKS">Remarks</label>
                                </div>
                                <div class="col-md-8">
                                    <input id="REMARKS" type="text" class="form-control"
                                           name="REMARKS" ng-model="model.REMARKS">
                                </div>
                            </div>
                        </div>
                    </div>
                </fieldset>
            </form>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">

            <fieldset>
                <legend style="width:140px">Vehicle List</legend>
                <div class="row" style="height: 57vh;">
                    <div class="col-lg-12 mb-4">
                        <div class="card" ng-show="model.LIST_VIEW == 'Active'" style="margin: 10px">
                            <div ui-grid="gridOptionsList" ui-grid-exporter ui-grid-auto-fit-columns ui-grid-resize-columns ui-grid-auto-resize
                                 style="font-family: 'Open Sans', Arial, sans-serif; color: #252222 !important; height: 50vh;" class="grid">
                            </div>
                        </div>
                    </div>
                </div>
            </fieldset>
        </div>
    </div>

    <partial name="~/Views/Shared/_Loader.cshtml" ng-show="showloader"></partial>
</div>
@section Scripts {
    <script src="~/ScriptsNg/SalesAndDistribution/Vehicle/Controller/VehicleInfoCtr.js"></script>
    <script src="~/ScriptsNg/SalesAndDistribution/Vehicle/Service/VehicleInfoServices.js"></script>
    <script src="~/ScriptsNg/Services/permissionProvider.js"></script>

    <script src="~/ScriptsNg/Services/gridRegistrationService.js"></script>
    <script src="~/Design/vendor/select2/dist/js/select2.min.js"></script>

    <script type="text/javascript">
        $(document).ready(function () {
            $(".select2-single").select2({
                placeholder: "Select...."
            });

        });
    </script>
}