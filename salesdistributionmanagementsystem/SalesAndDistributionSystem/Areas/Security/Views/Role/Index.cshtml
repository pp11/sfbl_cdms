@{
    ViewData["Title"] = "Role";
}
<link href="/css/site.css" rel="stylesheet">
<link href="/Design/vendor/select2/dist/css/select2.min.css" rel="stylesheet" type="text/css">



<div class="container-fluid" id="container-wrapper" ng-app="ngApp" ng-controller="ngGridCtrl">
    <div class="d-sm-flex align-items-center justify-content-between mt-1">
        <h4 class="h3 mb-0 text-gray-600">@ViewData["Title"].ToString()</h4>
        <ol class="breadcrumb mb-0 pb-1">
            <li class="breadcrumb-item" ng-show="!showDiv">
                <a href="/Security/Role/index" class="btn btn-warning btn-icon-split btn-sm">
                    <span class="icon text-white-50">
                        <i class="fas fa-sync-alt"></i>
                    </span>
                    <span class="text">Reload</span>
                </a>
            </li>
            <li class="breadcrumb-item" ng-show="!showDiv">
                <button type="button" class="btn btn-success btn-icon-split btn-sm" ng-disabled="formMenuCategoryAdd.$invalid || model.EMPLOYEE_ID <=0" ng-show="model.ADD_PERMISSION == 'Active'" ng-click="SaveData(model)">
                    <span class="icon text-white-50">
                        <i class="fas fa-save"></i>
                    </span>
                    <span class="text">Save</span>
                </button>
            </li>
        </ol>
    </div>
    <div class="row">
        <div class="col-lg-12">
            <div class="card mb-4">
                <div class="card-body p-1">
                    <form name="formMenuCategoryAdd">
                        <fieldset>
                            <div class="ml-3 mr-3 mt-3">
                                <div class="row">
                                    <div class="col-md-4 space-bottom">
                                        <div class="row">
                                            <div class="col-md-4">
                                                <label for="COMPANY_ID">Company</label>
                                            </div>
                                            <div class="col-md-8">
                                                <select class="select2-single form-control" id="COMPANY_ID" ng-disabled="model.USER_TYPE != 'SuperAdmin'"
                                                        name="COMPANY_ID" ng-model="model.COMPANY_ID" ng-change="DataLoad(model.COMPANY_ID) || UnitsLoad(model.COMPANY_ID)" style="width:100%">

                                                    <option ng-repeat="item in Companies" ng-selected="model.COMPANY_ID == item.COMPANY_ID" value="{{item.COMPANY_ID}}">{{item.COMPANY_NAME}}</option>
                                                </select>
                                            </div>

                                        </div>

                                    </div>
                                    <div class="col-md-4 space-bottom d-none">
                                        <div class="row">
                                            <div class="col-md-4">
                                                <label for="UNIT_ID">Unit</label>
                                            </div>
                                            <div class="col-md-8">
                                                <select class="select2-single form-control" id="UNIT_ID"
                                                        name="UNIT_ID" ng-model="model.UNIT_ID" style="width:100%">

                                                    <option ng-repeat="item in Units" value="{{item.UNIT_ID}}">{{item.UNIT_NAME}}</option>
                                                </select>
                                            </div>
                                        </div>

                                    </div>
                                    <div class="col-md-4 space-bottom">
                                        <div class="row">
                                            <div class="col-md-4">
                                                <label for="ROLE_NAME">Role Name</label>
                                            </div>
                                            <div class="col-md-8">
                                                <input type="text" class="form-control" autocomplete="off" data-val="true"
                                                       name="ROLE_NAME" ng-model="model.ROLE_NAME" required placeholder="Enter Role Name">

                                            </div>
                                        </div>

                                    </div>




                                </div>
                            </div>
                        </fieldset>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-lg-12">
            <div class="card">
                <div class="card-body p-2">
                    <fieldset>
                        <legend style="width:190px">Employee List</legend>
                        <div ng-show="model.LIST_VIEW == 'Active'">
                            <div ui-grid="gridOptionsList" ui-grid-exporter ui-grid-auto-fit-columns ui-grid-resize-columns ui-grid-auto-resize ui-grid-pinning
                                 style="color: #252222;height: 65vh " class="grid m-2">
                            </div>
                        </div>
                    </fieldset>
                </div>
            </div>
        </div>
    </div>
    <partial name="~/Views/Shared/_Loader.cshtml" ng-show="showloader"></partial>
</div>
@section Scripts {
    <script src="~/ScriptsNg/Security/Role/Controller/RolesCtr.js"></script>
    <script src="~/ScriptsNg/Security/Role/Service/RolesServices.js"></script>
    <script src="~/ScriptsNg/Services/gridRegistrationService.js"></script>
    <script src="~/ScriptsNg/Services/permissionProvider.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            $(".select2-single").select2({
                placeholder: "Select...."
            });

        });
    </script>
}


