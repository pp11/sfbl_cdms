@{
    ViewData["Title"] = "Product Price Info";
}
<link href="/css/site.css" rel="stylesheet">
<link href="/Design/vendor/select2/dist/css/select2.min.css" rel="stylesheet" type="text/css">


<div class="container-fluid" id="container-wrapper" ng-app="ngApp" ng-controller="ngGridCtrl">
    <div class="d-sm-flex align-items-center justify-content-between mb-4 sm-breadcrumb">
        <h4 class="h3 mb-0 text-gray-600">
            @ViewData["Title"].ToString()
        </h4>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><button class="btn  btn-danger mb-1" ng-click="ClearForm()">Reset</button></li>
            <li class="breadcrumb-item"><button type="button" style="width: 100px;color:white;cursor:pointer" pe="button" ng-disabled="formMenuCategoryAdd.$invalid || model.EMPLOYEE_PRICE<1 || model.SKU_ID<1" name="btnSubmit" class="btn  btn-success mb-1" ng-click="SaveData(model)">Save</button></li>


        </ol>
    </div>


    <div class="card mb-4">

        <div class="card-body">



            <form name="formMenuCategoryAdd">
                <fieldset>
                    <legend style="width:220px">Product Price Entry</legend>

                    <div class="row" style="margin:20px">

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="COMPANY_ID">Company</label>
                                </div>
                                <div class="col-md-8">
                                    <input id="COMPANY_ID" type="number" hidden class="form-control" required
                                           name="COMPANY_ID" ng-model="model.COMPANY_ID">
                                    <input id="COMPANY_NAME" type="text" disabled class="form-control" required
                                           name="COMPANY_NAME" ng-model="model.COMPANY_NAME">

                                </div>
                            </div>

                        </div>
                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    @*                                   <label for="UNIT_ID">Unit</label>
*@                          </div>
                                <div class="col-md-8">
                                    @* <select  class="select2-single form-control" id="UNIT_ID" required
                                      name="UNIT_ID" ng-model="model.UNIT_ID" style="width:100%">

                                      <option ng-repeat="item in Unit" value="{{item.UNIT_ID}}" ng-selected="item.UNIT_ID == 9" >{{item.UNIT_NAME}}</option>
                                     </select>*@
                                </div>
                            </div>

                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="MRP">Product Name<sup style="color:red">*</sup></label>
                                </div>
                                <div class="col-md-8">
                                    <select class="select2-single form-control" id="SKU_ID"
                                            name="SKU_ID" ng-model="model.SKU_ID" style="width:100%" ng-change="OnProductSelect()">

                                        <option ng-repeat="item in ProductList | orderBy : 'SKU_NAME'" value="{{item.SKU_ID}}" ng-selected="item.SKU_ID == model.SKU_ID">{{item.SKU_NAME}} -- {{item.SKU_CODE}} -- {{item.PACK_SIZE}}</option>
                                    </select>
                                    @* <div class="typeaheadcontainer">
                    <input type="text" autocomplete="off" style="width:100%;" class="form-control" name="SKU_CODE" required
                                                       ng-model="model.SKU_CODE"
                                                       uib-typeahead="Product as Product.SKU_NAME for Product in AutoCompleteDataLoadForPrpoduct($viewValue)| limitTo:5"
                                                       typeahead-append-to-body="true"
                                                       placeholder="Enter (Product) minimum 3 character"
                                                       typeahead-editable="false"
                                                       typeahead-on-select="typeaheadSelectedProduct(row.entity, $item)" />
                    </div>  *@
                                </div>
                            </div>

                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="MRP">MRP Price<sup style="color:red"></sup></label>
                                </div>
                                <div class="col-md-8">
                                    <input id="MRP" type="number" class="form-control" required
                                           name="MRP" ng-model="model.MRP">

                                </div>
                            </div>

                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="EMPLOYEE_PRICE">Employee Price<sup style="color:red">*</sup></label>
                                </div>
                                <div class="col-md-8">
                                    <input id="EMPLOYEE_PRICE" type="number" class="form-control" required
                                           name="EMPLOYEE_PRICE" ng-model="model.EMPLOYEE_PRICE">

                                </div>
                            </div>

                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="SPECIAL_PRICE">Special Price <sup style="color:red"></sup></label>
                                </div>
                                <div class="col-md-8">
                                    <input id="SPECIAL_PRICE" type="number" class="form-control" required
                                           name="SPECIAL_PRICE" ng-model="model.SPECIAL_PRICE">

                                </div>
                            </div>

                        </div>
                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="PRICE_EFFECT_DATE">Price Effect Start Date<sup style="color:red">*</sup></label>
                                </div>
                                <div class="col-md-8 simple-date2">
                                    <div class="input-group date">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text"><i class="fas fa-calendar"></i></span>
                                        </div>
                                        <input type="text" class="form-control" ng-model="model.PRICE_EFFECT_DATE" required value="" id="oneYearView">
                                    </div>
                                </div>
                            </div>

                        </div>
                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="GROSS_PROFIT">Gross Profit</label>
                                </div>
                                <div class="col-md-8">
                                    <input id="GROSS_PROFIT" type="number" class="form-control"
                                           name="GROSS_PROFIT" ng-model="model.GROSS_PROFIT">

                                </div>
                            </div>

                        </div>
                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="SUPPLIMENTARY_TAX">Supplimentary Tax</label>
                                </div>
                                <div class="col-md-8">
                                    <input id="SUPPLIMENTARY_TAX" type="number" class="form-control"
                                           name="SUPPLIMENTARY_TAX" ng-model="model.SUPPLIMENTARY_TAX">

                                </div>
                            </div>

                        </div>
                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="UNIT_TP">Unit TP<sup style="color:red"></sup></label>
                                </div>
                                <div class="col-md-8">
                                    <input id="UNIT_TP" type="number" class="form-control" required
                                           name="UNIT_TP" ng-model="model.UNIT_TP">

                                </div>
                            </div>

                        </div>


                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="UNIT_VAT">Unit Vat</label>
                                </div>
                                <div class="col-md-8">
                                    <input id="UNIT_VAT" type="number" class="form-control"
                                           name="UNIT_VAT" ng-model="model.UNIT_VAT">

                                </div>
                            </div>

                        </div>
                    </div>
                </fieldset>
            </form>


        </div>



    </div>
    <div class="card mb-4">

        <div class="card-body">

            <fieldset>
                <legend style="width:190px">Product Price List</legend>
                <div class="row" style="height: 57vh;">
                    <div class="col-lg-12 mb-4">
                        <div class="card" ng-show="model.LIST_VIEW == 'Active'" style="margin: 10px">
                            <div ui-grid="gridOptionsList" ui-grid-exporter ui-grid-auto-fit-columns ui-grid-resize-columns ui-grid-auto-resize
                                 style="font-family: 'Open Sans', Arial, sans-serif; color: #252222 !important; height: 50vh;" class="grid">
                            </div>
                        </div>
                    </div>
                </div>
            </fieldset>

        </div>
    </div>
    <partial name="~/Views/Shared/_Loader.cshtml" ng-show="showloader"></partial>
</div>

@section Scripts {
    <script src="~/ScriptsNg/SalesAndDistribution/ProductPrice/Controller/ProductPriceInfoCtr.js?v=2"></script>
    <script src="~/ScriptsNg/SalesAndDistribution/ProductPrice/Service/ProductPriceInfoServices.js"></script>
    <script src="~/ScriptsNg/Services/permissionProvider.js"></script>
    <script src="~/ScriptsNg/Services/gridRegistrationService.js"></script>
    <script src="~/Design/vendor/select2/dist/js/select2.min.js"></script>
    <script type="text/javascript">
           $(document).ready(function () {
               $(".select2-single").select2({
                   placeholder: "Select...."
               });

        });
    </script>
}