                                           name="ORDER_UNIT_NAME" ng-model="model.ORDER_UNIT_NAME">

                                </div>
                            </div>

                        </div>

                        <div class="col-md-4 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="ORDER_NO">Order No</label>
                                </div>
                                <div class="col-md-8">
                                    <input id="ORDER_NO" type="text" disabled class="form-control" required
                                           name="ORDER_NO" ng-model="model.ORDER_NO">
                                </div>
                            </div>

                        </div>
                        <div class="col-md-4 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="ADJUSTMENT_ID">Adjustment Name</label>
                                </div>
                                <div class="col-md-8">
                                    <select class="form-control" id="ADJUSTMENT_ID" required name="ADJUSTMENT_ID" ng-model="model.ADJUSTMENT_ID" style="width:100%" ng-change="onAdjustmentSelection()">
                                        <option ng-repeat="item in Adjustments" value="{{item.ADJUSTMENT_ID}}" ng-selected="item.ADJUSTMENT_ID == model.ADJUSTMENT_ID">{{item.ADJUSTMENT_NAME}}</option>
                                    </select>

                                </div>
                            </div>

                        </div>
                        <div class="col-md-4 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="ADJUSTMENT_AMOUNT">Adjustment Amount</label>
                                </div>
                                <div class="col-md-8">
                                    <input id="ADJUSTMENT_AMOUNT" type="number" class="form-control" required
                                           name="ADJUSTMENT_AMOUNT" ng-model="model.ADJUSTMENT_AMOUNT">

                                </div>
                            </div>

                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-2">
                                    <label for="REMARKS">Remarks</label>
                                </div>
                                <div class="col-md-10">
                                    <input id="REMARKS" type="text" class="form-control"
                                           name="REMARKS" ng-model="model.REMARKS">

                                </div>
                            </div>

                        </div>
                        <div class="col-md-2 space-bottom" ng-show="isRemBonusAdj">
                            <div class="row">
                                <div class="col-md-5">
                                    <label for="MONTH_NUMBER">Month</label>
                                </div>
                                <div class="col-md-7">
                                    <select id="MONTH_NUMBER" name="MONTH_NUMBER" ng-model="model.MONTH_NUMBER" class="form-control">
                                        <option value="01">January</option>
                                        <option value="02">February</option>
                                        <option value="03">March</option>
                                        <option value="04">April</option>
                                        <option value="05">May</option>
                                        <option value="06">June</option>
                                        <option value="07">July</option>
                                        <option value="08">August</option>
                                        <option value="09">September</option>
                                        <option value="10">October</option>
                                        <option value="11">November</option>
                                        <option value="12">December</option>
                                    </select>

                                </div>
                            </div>

                        </div>
                        <div class="col-md-2 space-bottom" ng-show="isRemBonusAdj">
                            <div class="row">
                                <div class="col-md-5">
                                    <label for="YEAR_NUMBER">Year</label>
                                </div>
                                <div class="col-md-7">
                                    <select id="YEAR_NUMBER" name="YEAR_NUMBER" ng-model="model.YEAR_NUMBER" class="form-control">
                                        <option ng-repeat="year in years" value="{{year}}">{{year}}</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2 space-bottom">
                            <div class="row">
                                <div class="col-md-12">
                                    <button type="button" style="width: 100px;color:white;cursor:pointer" pe="button" ng-disabled="gridOptions.data.length<2 || model.ORDER_STATUS == 'Complete'" name="btnSubmit" class="btn  btn-success mb-1" ng-click="SaveAdjustmentData(model)">Save</button>
                                </div>

                            </div>

                        </div>
                    </div>
                </fieldset>
            </form>


        </div>



    </div>
    <div class="card mb-4">

        <div class="card-body" ng-show="model.ORDER_MST_ID > 1 && model.ORDER_STATUS == 'Active' && gridOptionsListAdj.data.length>0">

            <fieldset>
