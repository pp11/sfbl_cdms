@{
    ViewData["Title"] = "Adjustment Info";
}

<link href="/css/site.css" rel="stylesheet">
<link href="/Design/vendor/select2/dist/css/select2.min.css" rel="stylesheet" type="text/css">




<div class="container-fluid" id="container-wrapper" ng-app="ngApp" ng-controller="ngAdjustmentInfoCtrl">


    <div class="d-sm-flex align-items-center justify-content-between mb-4 sm-breadcrumb">

        <h4 class="h3 mb-0 text-gray-600">

            @ViewData["Title"].ToString()

        </h4>

        <ol class="breadcrumb">

            <li class="breadcrumb-item"><button class="btn  btn-danger mb-1" ng-click="ResetData()">Reset</button></li>
            <li class="breadcrumb-item"><button type="button" style="width: 100px;color:white;cursor:pointer" pe="button" ng-disabled="frmAdjustmentInfo.$invalid" name="btnSave" class="btn  btn-success mb-1" ng-click="SaveData(model)">Save</button></li>


        </ol>
    </div>

    <div class="card mb-4">

        <div class="card-body">

            <form name="frmAdjustmentInfo">

                <fieldset>
                    <legend style="width:80px">Entry</legend>

                    <div class="row" style="margin:5px">


                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="COMPANY_ID" hidden>Company ID</label>
                                </div>
                                <div class="col-md-8">
                                    <input type="hidden" class="form-control" id="COMPANY_ID" name="COMPANY_ID" ng-model="model.COMPANY_ID" ng-disabled="isDisableCompanyId">
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="COMPANY_NAME" hidden>Company Name</label>
                                </div>
                                <div class="col-md-8">
                                    <input type="hidden" class="form-control" id="COMPANY_NAME" name="COMPANY_NAME" ng-model="model.COMPANY_NAME" ng-disabled="isDisableCompanyName" required>
                                </div>
                            </div>
                        </div>



                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="ADJUSTMENT_ID"> Adjustment ID</label>
                                </div>
                                <div class="col-md-8">
                                    <input type="text" class="form-control" id="ADJUSTMENT_ID" name="ADJUSTMENT_ID" ng-model="model.ADJUSTMENT_ID" ng-disabled="isDisableAdjustmentId">
                                </div>
                            </div>
                        </div>


                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="TEST_STATUS">Status</label>
                                </div>
                                <div class="col-md-8">
                                    <select class="form-control" id="ADJUSTMENT_STATUS" name="ADJUSTMENT_STATUS" ng-model="model.ADJUSTMENT_STATUS" style="width:100%">
                                        <option value="Active">Active</option>
                                        <option value="Inactive">Inactive</option>
                                    </select>
                                </div>
                            </div>
                        </div>



                        <div class="col-md-12 space-bottom">
                            <div class="row">
                                <div class="col-md-2">
                                    <label for="ADJUSTMENT_NAME"> Adjustment Name</label>
                                </div>
                                <div class="col-md-10">
                                    <input type="text" class="form-control" id="ADJUSTMENT_NAME" name="ADJUSTMENT_NAME" ng-model="model.ADJUSTMENT_NAME" required>
                                </div>
                            </div>
                        </div>




                        <div class="col-md-12 space-bottom">
                            <div class="row">
                                <div class="col-md-2">
                                    <label for="REMARKS"> Remarks</label>
                                </div>
                                <div class="col-md-10">
                                    <input type="text" class="form-control" id="REMARKS" name="REMARKS" ng-model="model.REMARKS">
                                </div>
                            </div>
                        </div>



                    </div>


                </fieldset>

            </form>

        </div>

    </div>






    <div class="card mb-4">
        <div class="card-body">
            <fieldset>
                <legend style="width:140px">Display</legend>
                <div class="row" style="height: 30vh;">
                    <div class="col-lg-12 mb-4">
                        <div class="card" style="margin: 5px">
                            @*ng-show="model.LIST_VIEW == 'Active'"*@
                            <div ui-grid="gridAdjustmentInfo" ui-grid-exporter ui-grid-auto-fit-columns ui-grid-resize-columns ui-grid-auto-resize
                                 style="font-family: 'Open Sans', Arial, sans-serif; color: #252222 !important; height: 25vh;" class="grid">
                            </div>
                        </div>
                    </div>
                </div>
            </fieldset>
        </div>
    </div>
</div>

@section Scripts{

    <script src="~/ScriptsNg/SalesAndDistribution/Adjustment/Controller/AdjustmentInfoCtr.js"></script>
    <script src="~/ScriptsNg/SalesAndDistribution/Adjustment/Service/AdjustmentInfoServices.js"></script>
    <script src="~/ScriptsNg/Services/gridRegistrationService.js"></script>
}
