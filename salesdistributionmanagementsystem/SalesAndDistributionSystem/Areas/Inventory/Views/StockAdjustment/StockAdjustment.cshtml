@{
    ViewData["Title"] = "Stock Adjustment";
}

<link href="/css/site.css" rel="stylesheet">
<link href="/Design/vendor/select2/dist/css/select2.min.css" rel="stylesheet" type="text/css">


<div class="container-fluid" id="container-wrapper" ng-app="ngApp" ng-controller="ngStockAdjustmentCtrl">


    <div class="d-sm-flex align-items-center justify-content-between mb-4 sm-breadcrumb">

        <h4 class="h3 mb-0 text-gray-600">

            @ViewData["Title"].ToString()

        </h4>

        <ol class="breadcrumb">

            <li class="breadcrumb-item"><button class="btn  btn-danger mb-1" ng-click="ResetData()">Reset</button></li>
            <li class="breadcrumb-item"><button type="button" style="width: 100px;color:white;cursor:pointer" pe="button" ng-disabled="frmStockAdjustment.$invalid" name="btnSave" class="btn  btn-success mb-1" ng-click="SaveData(model)">Save</button></li>
            @*<li class="breadcrumb-item"><button class="btn  btn-danger mb-1"  ng-click="GetSearchData()">Search</button></li>*@

        </ol>

    </div>


    <div class="card mb-4">

        <div class="card-body">

            <form name="frmStockAdjustment">

                <fieldset>
                    <legend style="width:80px">Entry</legend>

                    <div class="row" style="margin:5px">

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="COMPANY_ID">Company ID</label>
                                </div>
                                <div class="col-md-8">
                                    <input type="number" class="form-control" id="COMPANY_ID" name="COMPANY_ID" ng-model="model.COMPANY_ID" ng-disabled="isDisableCompanyId">
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="COMPANY_NAME">Company Name</label>
                                </div>
                                <div class="col-md-8">
                                    <input type="text" class="form-control" id="COMPANY_NAME" name="COMPANY_NAME" ng-model="model.COMPANY_NAME" ng-disabled="isDisableCompanyName">
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="UNIT_ID">Unit Name</label>
                                </div>
                                <div class="col-md-2">
                                    <input type="number" class="form-control" id="UNIT_ID" name="UNIT_ID" ng-model="model.UNIT_ID" ng-disabled="isDisableUnitId">
                                </div>
                                <div class="col-md-6">
                                    <input type="text" class="form-control" id="UNIT_NAME" name="UNIT_NAME" ng-model="model.UNIT_NAME" ng-disabled="isDisableUnitName">
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="ADJUSTMENT_ID"> Adjustment ID</label>
                                </div>
                                <div class="col-md-8">
                                    <input type="number" class="form-control" id="ADJUSTMENT_ID" name="ADJUSTMENT_ID" ng-model="model.ADJUSTMENT_ID" ng-disabled="isDisableAdjustmentId">
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label>SKU Name</label>
                                </div>
                                <div class="col-md-8">
                                    <select class="select2-single-Product form-control" id="SKU_ID" name="SKU_ID" ng-model="model.SKU_ID" ng-change="OnProductSelect()" style="width:100%">
                                        <option ng-repeat="item in Products | orderBy : 'SKU_NAME'" value="{{item.SKU_ID}}" ng-selected="item.SKU_ID == model.SKU_ID">{{item.SKU_NAME}} -- {{item.SKU_CODE}} -- {{item.PACK_SIZE}}</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="ADJUSTMENT_DATE"> Adjustment Date</label>
                                </div>
                                <div class="col-md-8">
                                    <input type="text" class="form-control" id="ADJUSTMENT_DATE" name="ADJUSTMENT_DATE" ng-model="model.ADJUSTMENT_DATE" ng-disabled="isDisableAdjustmentDate">
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">

                                <div class="col-md-4">
                                    <label for="SKU_CODE"> SKU Code</label>
                                </div>
                                <div class="col-md-3">
                                    <input type="text" class="form-control" id="SKU_CODE" name="SKU_CODE" ng-model="model.SKU_CODE" ng-disabled="isDisableSkuCode">
                                </div>

                                <div class="col-md-2">
                                    <label for="SKU_ID"> SKU ID</label>
                                </div>
                                <div class="col-md-3">
                                    <input type="number" class="form-control" id="SKU_ID" name="SKU_ID" ng-model="model.SKU_ID" ng-disabled="isDisableSkuId">
                                </div>


                            </div>
                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="PACK_SIZE"> Pack Size</label>
                                </div>
                                <div class="col-md-3">
                                    <input type="text" class="form-control" id="PACK_SIZE" name="PACK_SIZE" ng-model="model.PACK_SIZE" ng-disabled="isDisablePackSize">
                                </div>


                                <div class="col-md-2">
                                    <label for="UNIT_TP"> Unit TP</label>
                                </div>
                                <div class="col-md-3">
                                    <input type="number" class="form-control" id="UNIT_TP" name="UNIT_TP" ng-model="model.UNIT_TP" ng-disabled="isDisableUnitTp">
                                </div>

                            </div>
                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="BATCH_NO"> Batch No</label>
                                </div>
                                <div class="col-md-8">
                                    <input type="text" class="form-control" id="BATCH_NO" name="BATCH_NO" ng-model="model.BATCH_NO" placeholder="Double click here to select batch" ng-dblclick="GetBatchList()" readonly required>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="TEST_STATUS">Stock Type</label>
                                </div>
                                <div class="col-md-8">
                                    <select class="form-control" id="STOCK_TYPE" name="STOCK_TYPE" ng-model="model.STOCK_TYPE" style="width:100%" readonly>
                                        <option value="P">Pass Stock</option>
                                        <option value="Q">Quarantine stock</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="TEST_STATUS">Adjustment Type</label>
                                </div>
                                <div class="col-md-8">
                                    <select class="form-control" id="ADJUSTMENT_TYPE" name="ADJUSTMENT_TYPE" ng-model="model.ADJUSTMENT_TYPE" ng-change="OnChangeAdjustmentType()" style="width:100%">
                                        <option value="G">Gain</option>
                                        <option value="L">Lose</option>
                                    </select>
                                </div>
                            </div>
                        </div>


                        <div class="col-md-6 space-bottom">

                            <div class="row">

                                <div class="col-md-4">
                                    <label for="ADJUSTMENT_DATE"> Adjustment Qty</label>
                                </div>
                                <div class="col-md-3">
                                    <input type="number" class="form-control" id="ADJUSTMENT_QTY" name="ADJUSTMENT_QTY" ng-model="model.ADJUSTMENT_QTY" ng-change="OnChangeAdjustmentQty()">
                                </div>

                                <div class="col-md-2">
                                    <label for="BATCH_STOCK_QTY"> Stock Qty</label>
                                </div>
                                <div class="col-md-3">
                                    <input type="number" class="form-control" id="BATCH_STOCK_QTY" name="BATCH_STOCK_QTY" ng-model="model.BATCH_STOCK_QTY" ng-disabled="isDisableBatchStockQty">
                                </div>

                            </div>

                        </div>

                        <div class="col-md-12 space-bottom">
                            <div class="row">
                                <div class="col-md-2">
                                    <label for="REMARKS"> Remarks</label>
                                </div>
                                <div class="col-md-10">
                                    <input type="text" class="form-control" id="REMARKS" name="REMARKS" ng-model="model.REMARKS">
                                </div>
                            </div>
                        </div>



                    </div>








                    <div class="modal fade" id="BatchListModal" tabindex="-1" role="dialog"
                         aria-labelledby="BatchListModalTitle" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-scrollable" role="document" style="max-width:1200px">
                            <div class="modal-content" style="height:1000px !important">
                                <div class="modal-header">
                                    <h5 class="modal-title" id="BatchListModalTitle">Batch List</h5>
                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                        <span aria-hidden="true">&times;</span>
                                    </button>
                                </div>
                                <div class="modal-body">
                                    <div class="row" style="height: 75vh;">
                                        <div class="col-lg-12 mb-4">
                                            <div class="card" style="margin: 10px">
                                                @*ng-show="model.LIST_VIEW == 'Active'"*@
                                                <div ui-grid="gridBatchList" ui-grid-exporter ui-grid-auto-fit-columns ui-grid-resize-columns ui-grid-auto-resize
                                                     style="font-family: 'Open Sans', Arial, sans-serif; color: #252222 !important; height: 70vh;" class="grid">
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                                @*
                                        <div class="modal-footer">
                                          <button type="button" class="btn btn-outline-primary" data-dismiss="modal">Close</button>
                                          <button type="button" class="btn btn-primary">Save changes</button>
                                        </div>
                                        *@
                            </div>
                        </div>
                    </div>




                    <div class="modal fade" id="SearchDataModal" tabindex="-1" role="dialog"
                         aria-labelledby="SearchDataModalTitle" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-scrollable" role="document" style="max-width:1200px">
                            <div class="modal-content" style="height:1000px !important">
                                <div class="modal-header">
                                    <h5 class="modal-title" id="SearchDataModalTitle">Search Data</h5>
                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                        <span aria-hidden="true">&times;</span>
                                    </button>
                                </div>
                                <div class="modal-body">
                                    <div class="row" style="height: 75vh;">
                                        <div class="col-lg-12 mb-4">
                                            <div class="card" style="margin: 10px">
                                                <div ui-grid="gridSearchData" ui-grid-exporter ui-grid-auto-fit-columns ui-grid-resize-columns ui-grid-auto-resize
                                                     style="font-family: 'Open Sans', Arial, sans-serif; color: #252222 !important; height: 70vh;" class="grid">
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </fieldset>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/ScriptsNg/Inventory/StockAdjustment/Controller/StockAdjustmentCtr.js"></script>
    <script src="~/ScriptsNg/Inventory/StockAdjustment/Service/StockAdjustmentServices.js"></script>
    <script src="~/ScriptsNg/Services/gridRegistrationService.js"></script>
}