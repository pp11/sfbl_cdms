@{
    ViewData["Title"] = "User Menu Config";
}
@section Styles{
    <link href="/css/site.css" rel="stylesheet">
}
<div class="container-fluid" id="container-wrapper" ng-app="ngApp" ng-controller="ngGridCtrl">
    <div class="d-sm-flex align-items-center justify-content-between mt-1">
        <h1 class="h3 mb-0 text-gray-800">@ViewData["Title"].ToString()</h1>
        <ol class="breadcrumb mb-0 pb-1">
            <li class="breadcrumb-item">
                <a href="/Security/MenuPermission/Index" class="btn btn-warning btn-icon-split btn-sm">
                    <span class="icon text-white-50">
                        <i class="fas fa-sync-alt"></i>
                    </span>
                    <span class="text">Reload</span>
                </a>
            </li>
        </ol>
    </div>
    <!-- row -->
    <div class="row">
        <div class="col-lg-12">
            <div class="card mb-4">
                <div class="card-body p-1">
                    <form name="formMenuCategoryAdd">
                        <fieldset>
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                            <div class="ml-3 mr-3 mt-3">
                                <div class="row">
                                    <div class="form-group col-md-6">
                                        <label for="Role_Id">Select User</label>
                                        <div class="typeaheadcontainer">
                                            <input type="text" autocomplete="off" style="width:100%;" class="form-control" name="USER_NAME"
                                                   ng-model="model.USER_NAME"
                                                   uib-typeahead="User as User.USER_NAME for User in AutoCompleteDataLoadForUser($viewValue)| limitTo:5"
                                                   typeahead-append-to-body="true"
                                                   placeholder="Enter (User Name) minimum 3 character"
                                                   typeahead-editable="false"
                                                   typeahead-on-select="typeaheadSelectedUser(row.entity, $item)" />
                                        </div>
                                    </div>
                                    <div class="form-group col-md-6">
                                        <div class="row" style="margin-top:5px">
                                            <div class="col-md-6">
                                                <label for="select2Multiple"></label>
                                                <button ng-disabled="model.USER_ID<=0" type="button" class="form-control btn btn-outline-secondary" style="margin-top:5px" pe="button" name="btnSubmit" ng-show="model.LIST_VIEW == 'Active'" ng-click="UserMenuConfigSelectionList()"> Load</button>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="select2Multiple"></label>
                                                <button type="button" class="form-control btn btn-outline-success" style="margin-top:5px" pe="button" name="btnSubmit" ng-show="model.ADD_PERMISSION == 'Active'" ng-disabled="model.USER_ID == null || model.USER_ID < 1" ng-click="SaveData(model)"> Submit</button>

                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </fieldset>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-lg-12">
            <div class="card">
                <div class="card-body p-2">
                    <fieldset>
                        <legend style="width:190px">Manu List</legend>
                        <div ng-show="model.LIST_VIEW == 'Active'">
                            <div ui-grid="gridOptionsList" ui-grid-exporter ui-grid-auto-fit-columns ui-grid-resize-columns ui-grid-auto-resize ui-grid-pinning
                                 style="color: #252222;height: 59.5vh " class="grid m-2">
                            </div>
                        </div>
                    </fieldset>
                </div>
            </div>
        </div>
    </div>
    <partial name="~/Views/Shared/_Loader.cshtml" ng-show="showloader"></partial>
</div>
@section Scripts {
    <script src="~/ScriptsNg/Security/MenuPermission/Controller/UserMenuConfigCtr.js?v=ridwanSL1"></script>
    <script src="~/ScriptsNg/Security/MenuPermission/Service/UserMenuConfigService.js?v=ridwanSL1"></script>
    <script src="~/ScriptsNg/Services/permissionProvider.js"></script>
    <script src="~/ScriptsNg/Services/gridRegistrationService.js"></script>
}
