@{
    ViewData["Title"] = "Module";
}


<link href="/css/site.css" rel="stylesheet">
<!-- Container Fluid -->
<div class="container-fluid" id="container-wrapper" ng-app="ngApp" ng-controller="ngGridCtrl">
    <div class="d-sm-flex align-items-center justify-content-between mt-1">
        <h1 class="h3 mb-0 text-gray-800">@ViewData["Title"].ToString()</h1>
        <ol class="breadcrumb mb-0 pb-1">
            <li class="breadcrumb-item">
                <a href="/Security/MenuCategory/index" class="btn btn-warning btn-icon-split btn-sm">
                    <span class="icon text-white-50">
                        <i class="fas fa-sync-alt"></i>
                    </span>
                    <span class="text">Refresh</span>
                </a>
            </li>
            <li class="breadcrumb-item">
                <button type="button" class="btn btn-success btn-icon-split btn-sm" ng-disabled="formMenuCategoryAdd.$invalid" ng-show="model.ADD_PERMISSION == 'Active'" ng-click="SaveData(model)">
                    <span class="icon text-white-50">
                        <i class="fas fa-save"></i>
                    </span>
                    <span class="text">Save</span>
                </button>
            </li>
        </ol>
    </div>
    <!-- row -->
    <div class="row">
        <!-- Basic Button -->
        <div class="col-lg-12">
            <div class="card mb-1">
                <div class="card-body p-2">
                    <form name="formMenuCategoryAdd">
                        <fieldset>
                            <legend style="width:140px">Module Entry</legend>

                            <div class="row" style="margin:20px">

                                <div class="col-md-4 space-bottom">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label for="COMPANY_ID">Company</label>
                                        </div>
                                        <div class="col-md-8">
                                            <select class="select2-single form-control" id="COMPANY_ID" ng-disabled="model.USER_TYPE != 'SuperAdmin'"
                                                    name="COMPANY_ID" ng-model="model.COMPANY_ID" ng-change="DataLoad(model.COMPANY_ID)" style="width:100%">

                                                <option ng-repeat="item in Companies" ng-selected="model.COMPANY_ID == item.COMPANY_ID" value="{{item.COMPANY_ID}}">{{item.COMPANY_NAME}}</option>
                                            </select>
                                        </div>

                                    </div>

                                </div>
                                <div class="col-md-4 space-bottom">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label for="MODULE_NAME">Module Name</label>
                                        </div>
                                        <div class="col-md-8">
                                            <input type="text" class="form-control" autocomplete="off" data-val="true"
                                                   name="MODULE_NAME" ng-model="model.MODULE_NAME" required placeholder="Enter Menu Module Name">
                                        </div>
                                    </div>

                                </div>

                                <div class="col-md-4 space-bottom">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label for="ORDER_BY_NO"> Serial No</label>
                                        </div>
                                        <div class="col-md-8">
                                            <input id="ORDER_BY_NO" type="number" class="form-control" value="0" required min="0"
                                                   name="ORDER_BY_NO" ng-model="model.ORDER_BY_NO" placeholder="Enter Menu Module Serial">

                                        </div>
                                    </div>

                                </div>
                            </div>
                        </fieldset>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-12">
            <div class="card mb-1">

                <div class="card-body p-2">

                    <fieldset>
                        <legend style="width:140px">Module List</legend>
                        <div class="row" style="height: 60vh;">
                            <div class="col-lg-12 mb-4">
                                <div class="card" ng-show="model.LIST_VIEW == 'Active'" style="margin: 10px">
                                    <div ui-grid="gridOptionsList" ui-grid-exporter ui-grid-auto-fit-columns ui-grid-resize-columns ui-grid-auto-resize
                                         style="font-family: 'Open Sans', Arial, sans-serif; color: #252222 !important; height: 55vh;" class="grid">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </fieldset>

                </div>
            </div>
        </div>
    </div>
    <!-- Row -->
    <partial name="~/Views/Shared/_Loader.cshtml" ng-show="showloader"></partial>

</div>
<!-- Container Fluid -->
@section Scripts {
    <script src="~/ScriptsNg/Security/MenuCategory/Controller/MenuCategoryCtr.js?v=ridwanSL1"></script>
    <script src="~/ScriptsNg/Security/MenuCategory/Service/MenuCategoryServices.js?v=ridwanSL1"></script>
    <script src="~/ScriptsNg/Services/permissionProvider.js"></script>
    <script src="~/ScriptsNg/Services/gridRegistrationService.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            $(".select2-single").select2({
                placeholder: "Select...."
            });

        });
    </script>
}