                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>      SELECT L.DIVISION_ID,
             L.DIVISION_CODE,
             L.DIVISION_NAME,
             L.REGION_ID,
             L.REGION_CODE,
             L.REGION_NAME,
             L.AREA_ID,
             L.AREA_CODE,
             L.AREA_NAME,
             L.TERRITORY_ID,
             L.TERRITORY_CODE,
             L.TERRITORY_NAME,
             L.MARKET_ID,
             L.MARKET_CODE,
             L.MARKET_NAME,
             L.CUSTOMER_CODE,
             L.CUSTOMER_NAME,
             A.CUSTOMER_ID,
             A.RETURN_UNIT_ID,
             U.UNIT_NAME,
             A.INVOICE_NO,
             A.INVOICE_DATE,
             A.RETURN_DATE,
             A.NET_RETURN_AMOUNT,
             A.NET_INVOICE_AMOUNT,
             A.TDS_AMOUNT,
               A.CUSTOMER_DISC_AMOUNT
             + A.CUSTOMER_ADD2_DISC_AMOUNT
             + A.CUSTOMER_ADD1_DISC_AMOUNT
             + A.CUSTOMER_PRODUCT_DISC_AMOUNT
             + A.CUSTOMER_ADD2_DISC_AMOUNT
             + A.CUSTOMER_ADD1_DISC_AMOUNT
                DISC_AMOUNT,
                B.UNIT_TP,
                B.SKU_CODE,
                B.SKU_ID, 
                B.RETURN_QTY,
                C.SKU_NAME,
                C.PACK_SIZE,
               A.TOTAL_LOADING_CHARGE_AMOUNT
        FROM RETURN_MST A,RETURN_DTL B,PRODUCT_INFO C, VW_LOCATION_CUSTOMER_RELATION L, COMPANY_INFO U
        WHERE A.MST_ID=B.MST_ID 
             AND B.SKU_ID=C.SKU_ID
             AND A.CUSTOMER_ID = L.CUSTOMER_ID
             AND A.COMPANY_ID = U.COMPANY_ID  AND A.RETURN_UNIT_ID = U.UNIT_ID</CommandText>
