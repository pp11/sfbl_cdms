@model SalesAndDistributionSystem.Domain.Models.Entities.SalesAndDistribution.DEBIT_CREDIT_ADJ
@{
    ViewData["Title"] = "Debit/Credit Adjustment";
}
<link href="/css/site.css" rel="stylesheet">
<link href="/Design/vendor/select2/dist/css/select2.min.css" rel="stylesheet" type="text/css">


<div class="container-fluid" id="container-wrapper" ng-app="ngApp" ng-controller="ngGridCtrl">
    <div class="d-sm-flex align-items-center justify-content-between mb-4 sm-breadcrumb">
        <h4 class="h3 mb-0 text-gray-600">
            @ViewData["Title"].ToString()
        </h4>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><button class="btn  btn-info mb-1" ng-click="ClearForm()">Clear Form Data</button></li>
            <li class="breadcrumb-item"><button class="btn  btn-danger mb-1" ng-click="Reload()">Reload</button></li>
            <li class="breadcrumb-item"><button type="button" style="width: 100px;color:white;cursor:pointer" name="btnSubmit" class="btn  btn-success mb-1" ng-click="SaveData(model)">Save</button></li>
        </ol>
    </div>


    <div class="card mb-4">
        <div class="card-body">
            <form name="formMenuCategoryAdd">
                <fieldset>
                    <legend style="width:300px">Debit/Credit Adjustment Entry</legend>
                    <div class="row" style="margin:20px">
                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="COMPANY_ID">Company</label>
                                </div>
                                <div class="col-md-8">
                                    <input id="COMPANY_ID" type="number" hidden class="form-control" required
                                           name="COMPANY_ID" ng-model="model.COMPANY_ID">
                                    <input id="COMPANY_NAME" type="text" disabled class="form-control" required
                                           name="COMPANY_NAME" ng-model="model.COMPANY_NAME">
                                    <input id="ORDER_UNIT_ID" type="number" hidden class="form-control" required
                                           name="ORDER_UNIT_ID" ng-model="model.ORDER_UNIT_ID">
                                    <input id="ORDER_UNIT_NAME" type="text" hidden class="form-control"
                                           name="ORDER_UNIT_NAME" ng-model="model.ORDER_UNIT_NAME">

                                </div>
                            </div>

                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="ADJUSTMENT_NO">Adjustment No</label>
                                </div>
                                <div class="col-md-8">
                                    <input id="ADJUSTMENT_NO" type="text" disabled class="form-control" required placeholder="Auto Complete"
                                           name="ADJUSTMENT_NO" ng-model="model.ADJUSTMENT_NO">
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="CUSTOMER_ID">Customer</label>
                                </div>
                                <div class="col-md-8">
                                    <select class="form-control select2-single" id="CUSTOMER_ID" required name="CUSTOMER_ID" ng-model="model.CUSTOMER_ID" style="width:100%" ng-change="onSelectCustomer()">
                                        <option ng-repeat="item in Customers" value="{{item.CUSTOMER_ID}}" ng-selected="item.CUSTOMER_ID == model.CUSTOMER_ID">{{item.CUSTOMER_CODE}}-{{item.CUSTOMER_NAME}}</option>
                                    </select>
                                </div>
                            </div>

                        </div>
                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="ADJUSTMENT_AMOUNT">Adjustment Amount </label>
                                </div>
                                <div class="col-md-8">
                                    <input id="ADJUSTMENT_AMOUNT" type="number" class="form-control" required
                                           name="ADJUSTMENT_AMOUNT" ng-model="model.ADJUSTMENT_AMOUNT">

                                </div>
                            </div>

                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="REMARKS">Remarks</label>
                                </div>
                                <div class="col-md-8">
                                    <input id="REMARKS" type="text" class="form-control"
                                           name="REMARKS" ng-model="model.REMARKS">

                                </div>
                            </div>

                        </div>
                    </div>
                </fieldset>
            </form>
        </div>
    </div>
    <div class="card mb-4">
        <div class="card-body">
            <fieldset>
                <legend style="width:300px">Debit/Credit Adjustment List</legend>
                <div class="row" style="height: 57vh;">
                    <div class="col-lg-12 mb-4">
                        <div class="card" ng-show="model.LIST_VIEW == 'Active'" style="margin: 10px">
                            <div ui-grid="gridOptionsListAdj" ui-grid-exporter ui-grid-auto-fit-columns ui-grid-resize-columns ui-grid-auto-resize
                                 style="font-family: 'Open Sans', Arial, sans-serif; color: #252222 !important; height: 50vh;" class="grid">
                            </div>
                        </div>
                    </div>
                </div>
            </fieldset>

        </div>
    </div>
    <partial name="~/Views/Shared/_Loader.cshtml" ng-show="showloader"></partial>
</div>

@section Scripts {
    <script src="~/ScriptsNg/SalesAndDistribution/DebitCreditAdj/Controller/AdjustmentCtr.js"></script>
    <script src="~/ScriptsNg/SalesAndDistribution/DebitCreditAdj/Service/AdjustmentServices.js"></script>
    <script src="~/ScriptsNg/Services/permissionProvider.js"></script>
    <script src="~/ScriptsNg/Services/gridRegistrationService.js"></script>
    <script src="~/Design/vendor/select2/dist/js/select2.min.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            $(".select2-single").select2({
                placeholder: "Select...."
            });
        });
    </script>
}