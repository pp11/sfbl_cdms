@model SalesAndDistributionSystem.Domain.Models.Entities.SalesAndDistribution.DEPOT_REQUISITION_ISSUE_MST
@{
    ViewData["Title"] = "Requisition Issue";
}
<link href="/css/site.css" rel="stylesheet">
<link href="/Design/vendor/select2/dist/css/select2.min.css" rel="stylesheet" type="text/css">


<div class="container-fluid" id="container-wrapper" ng-app="ngApp" ng-controller="ngGridCtrl">
    <div class="d-sm-flex align-items-center justify-content-between mb-4 sm-breadcrumb">
        <h4 class="h3 mb-0 text-gray-600">
            @ViewData["Title"].ToString()
        </h4>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><button class="btn  btn-danger mb-1" ng-click="ClearForm()">Reset</button></li>
            <li class="breadcrumb-item"><button type="button" style="width: 100px;color:white;cursor:pointer" pe="button" name="btnSubmit" class="btn  btn-success mb-1" ng-click="SaveData(model)">Save</button></li>
            <li class="breadcrumb-item"><a class="btn  btn-primary mb-1" href="/Inventory/RequisitionIssue/List">Search</a></li>
            <li class="breadcrumb-item"><a class="btn  btn-primary mb-1" href="/Inventory/RequisitionIssue/PendingList">Pending List</a></li>
        </ol>
    </div>


    <div class="card mb-4">
        <div class="card-body">
            <form name="formMenuCategoryAdd">
                <span ng-init="GetEditDataById('@Model.MST_ID_ENCRYPTED')"></span>
                <fieldset>
                    <legend style="width:220px">Requisition Issue Master</legend>

                    <div class="row" style="margin:20px">
                        <div class="col-md-4 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="MRP">Requisition No</label>
                                </div>
                                <div class="col-md-8">
                                    @if (Model.MST_ID_ENCRYPTED == "0")
                                    {
                                        <select class="select2-single form-control" id="REQUISITION_NO" @*ng-disabled="model.USER_TYPE != 'SuperAdmin'"*@
                                                name="REQUISITION_NO" ng-model="model.REQUISITION_NO" style="width:100%" ng-change="LoadRequisitionDtlData()">

                                            <option ng-repeat="item in RequisitionList" ng-selected="item.REQUISITION_NO == model.REQUISITION_NO" value="{{item.REQUISITION_NO}}">{{item.REQUISITION_NO}}</option>
                                        </select>
                                    }
                                    else
                                    {
                                        <input id="REQUISITION_NO" type="text" class="form-control" required disabled
                                               name="REQUISITION_NO" ng-model="model.REQUISITION_NO" placeholder="REQUISITION NO">
                                    }
                                </div>
                            </div>

                        </div>

                        <div class="col-md-4 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="ISSUE_NO">Issue No</label>
                                </div>
                                <div class="col-md-8">
                                    <input id="ISSUE_NO" ng-disabled="true" type="text" class="form-control" required
                                           name="ISSUE_NO" ng-model="model.ISSUE_NO">
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="MRP">Requisition Date</label>
                                </div>
                                <div class="col-md-8">
                                    <input id="REQUISITION_DATE" type="text" disabled class="form-control" required
                                           name="REQUISITION_DATE" ng-model="model.REQUISITION_DATE">

                                </div>
                            </div>

                        </div>

                        <div class="col-md-4 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="MRP">Requisition Amount</label>
                                </div>
                                <div class="col-md-8">
                                    <input id="REQUISITION_AMOUNT" type="number" class="form-control" required disabled
                                           name="REQUISITION_AMOUNT" ng-model="model.REQUISITION_AMOUNT">

                                </div>
                            </div>

                        </div>

                        <div class="col-md-4 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="UNIT_ID">Requisition Unit</label>
                                </div>
                                <div class="col-md-8">

                                    <select class="select2-single form-control" id="REQUISITION_UNIT_ID" disabled
                                            name="REQUISITION_UNIT_ID" ng-model="model.REQUISITION_UNIT_ID" style="width:100%">

                                        <option ng-repeat="item in Unit" value="{{item.UNIT_ID}}" ng-selected="item.UNIT_ID == model.REQUISITION_UNIT_ID">{{item.UNIT_NAME}}</option>
                                    </select>
                                </div>
                            </div>

                        </div>
                        <div class="col-md-4 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="UNIT_NAME">Issue Unit</label>
                                </div>
                                <div class="col-md-8">
                                    <input id="UNIT_NAME" ng-disabled="true" type="text" class="form-control" required
                                           name="UNIT_NAME" ng-model="model.UNIT_NAME">
                                </div>
                            </div>
                        </div>




                        <div class="col-md-4 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="MRP">Issue Amount</label>
                                </div>
                                <div class="col-md-8">
                                    <input id="ISSUE_AMOUNT" type="number" class="form-control" required disabled
                                           name="ISSUE_AMOUNT" ng-model="model.ISSUE_AMOUNT">

                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="MRP">Total Volume</label>
                                </div>
                                <div class="col-md-8">
                                    <input id="Total_Volume" type="number" class="form-control" required disabled
                                           name="TOTAL_VOLUME" ng-model="model.TOTAL_VOLUME">

                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="MRP">Total Weight</label>
                                </div>
                                <div class="col-md-8">
                                    <input id="TOTAL_WEIGHT" type="number" class="form-control" required disabled
                                           name="TOTAL_WEIGHT" ng-model="model.TOTAL_WEIGHT">
                                </div>
                            </div>
                        </div>
                        @*<div class="col-md-4 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="SPECIAL_PRICE">Status</label>
                                </div>
                                <div class="col-md-8">

                                    <select class="form-control" id="STATUS" name="STATUS" ng-model="model.STATUS" style="width:100%">

                                        <option ng-repeat="item in Status" value="{{item.STATUS}}">{{ item.STATUS }}</option>

                                    </select>
                                </div>
                            </div>

                        </div>*@
                        <div class="col-md-4 space-bottom">
                            <div class="row">
                                <div class="col-md-4" hidden>
                                    <label for="PRICE_EFFECT_DATE">Remarks</label>
                                </div>
                                <div class="col-md-8" hidden>
                                    <input id="REMARKS" type="text" class="form-control" required
                                           name="REMARKS" ng-model="model.REMARKS">

                                </div>
                            </div>

                        </div>

                    </div>
                </fieldset>
                <fieldset style="margin-top:10px;">
                    <legend style="width:220px">Issue Detail</legend>

                    <div class="row" style="margin:20px">
                        <div class="col-lg-12 mb-4" style="height: 37vh;">
                            <div class="card" ng-show="model.LIST_VIEW == 'Active'">
                                <div ui-grid="gridOptionsList" ui-grid-exporter ui-grid-auto-fit-columns ui-grid-resize-columns ui-grid-auto-resize
                                     style="font-family: 'Open Sans', Arial, sans-serif; color: #252222 !important; height: 35vh;" class="grid">
                                </div>
                            </div>
                        </div>
                    </div>
                </fieldset>
            </form>


        </div>

    </div>
    <partial name="~/Views/Shared/_Loader.cshtml" ng-show="showloader"></partial>
</div>
@section Scripts {
    <script src="~/ScriptsNg/Inventory/RequisitionIssue/Controller/RequisitionIssueCtr.js"></script>
    <script src="~/ScriptsNg/Inventory/RequisitionIssue/Service/RequisitionIssueService.js"></script>
    <script src="~/ScriptsNg/Services/permissionProvider.js"></script>
    <script src="~/ScriptsNg/Security/Notification/Service/LiveNotificationServices.js"></script>
    <script src="~/ScriptsNg/Services/gridRegistrationService.js"></script>
    <script src="~/Design/vendor/select2/dist/js/select2.min.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            $(".select2-single").select2({
                placeholder: "Select...."
            });

        });
    </script>
    <style>
        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
    </style>
}