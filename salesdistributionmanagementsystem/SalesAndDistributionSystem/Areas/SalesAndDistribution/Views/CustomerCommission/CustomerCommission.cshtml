@{
    ViewData["Title"] = "Customer Commission";
}
<link href="/css/site.css" rel="stylesheet">
<link href="/Design/vendor/select2/dist/css/select2.min.css" rel="stylesheet" type="text/css">
<div class="container-fluid" id="container-wrapper" ng-app="ngApp" ng-controller="ngGridCtrl">
    <div class="d-sm-flex align-items-center justify-content-between mb-4 sm-breadcrumb">
        <h4 class="h3 mb-0 text-gray-600">
            @ViewData["Title"].ToString()
        </h4>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><button class="btn  btn-danger mb-1" ng-click="ClearForm()">Reset</button></li>
            <li class="breadcrumb-item"><button type="button" style="width: 100px;color:white;cursor:pointer" pe="button" ng-disabled="formMenuCategoryAdd.$invalid" name="btnSubmit" class="btn  btn-success mb-1" ng-click="SaveData(model)">Save</button></li>


        </ol>
    </div>


    <div class="card mb-4">

        <div class="card-body">

            <form name="formMenuCategoryAdd">
                <fieldset>
                    <legend style="width:200px">Commission Entry</legend>

                    <div class="row" style="margin:20px">

                        <div class="col-md-12 space-bottom">
                            <div class="row">
                                <div class="col-md-2">
                                    <label for="COMMISSION_ID">Commission ID</label>
                                </div>
                                <div class="col-md-2">
                                    <input id="COMMISSION_ID" disabled type="number" class="form-control" name="COMMISSION_ID" ng-model="model.COMMISSION_ID">
                                    @*<input id="COMPANY_NAME" type="text" disabled class="form-control"  required   name="COMPANY_NAME"  ng-model="model.COMPANY_NAME" >*@

                                </div>
                                <div class="col-md-2">
                                    <label for="COMPANY_ID">Company</label>
                                </div>
                                <div class="col-md-2">
                                    <input id="COMPANY_ID" type="text" hidden class="form-control" required name="COMPANY_ID" ng-model="model.COMPANY_ID">
                                    <input id="COMPANY_NAME" type="text" disabled class="form-control" required name="COMPANY_NAME" ng-model="model.COMPANY_NAME">
                                </div>

                                <div class="col-md-2">
                                    <label for="ENTRY_DATE">Entry Date<sup>*</sup></label>
                                </div>
                                <div class="col-md-2">
                                    <input id="ENTRY_DATE" disabled type="text" class="form-control" required name="ENTRY_DATE" ng-model="model.ENTRY_DATE">
                                </div>
                            </div>
                        </div>
                        <div class="col-md-12 space-bottom">
                            <div class="row">
                                <div class="col-md-2">
                                    <label for="CUSTOMER_NAME">Customer Name<sup>*</sup></label>
                                </div>
                                <div class="col-md-6">
                                    @*<input id="CUSTOMER_NAME" type="text"  class="form-control"  required  name="CUSTOMER_NAME"  ng-model="model.CUSTOMER_NAME" >   *@

                                    <select class="select2-single-Customer form-control" id="CUSTOMER_ID" ng-change="changeCustomer()" required
                                            name="CUSTOMER_ID" ng-model="model.CUSTOMER_ID" style="width:100%">

                                        <option ng-repeat="item in CustomerData" value="{{item.CUSTOMER_ID}}" ng-selected="item.CUSTOMER_ID == model.CUSTOMER_ID">{{item.CUSTOMER_NAME}} -- {{item.CUSTOMER_CODE}}</option>
                                    </select>

                                </div>

                                <div class="col-md-2">
                                    <label for="CUSTOMER_CODE">Customer Code<sup>*</sup></label>
                                </div>
                                <div class="col-md-2">
                                    @*<input id="CUSTOMER_ID" hidden type="text"  class="form-control"  required  name="CUSTOMER_ID"  ng-model="model.CUSTOMER_ID" >   *@
                                    <input id="CUSTOMER_CODE" type="text" class="form-control" readonly required name="CUSTOMER_CODE" ng-model="model.CUSTOMER_CODE">
                                </div>

                            </div>

                        </div>

                        <div class="col-md-12 space-bottom">
                            <div class="row">
                                <div class="col-md-2">
                                    <label for="COMMISSION_TYPE">Commission Type<sup>*</sup></label>
                                </div>
                                <div class="col-md-2">

                                    @*   <select class="form-control form-white input-sm" id="COMMISSION_TYPE" ng-model="COMMISSION_TYPE" required>
                                        <option value="PCT">PCT</option>
                                        <option value="Fixed Value">Fixed Value</option>
                                     </select>*@
                                    <select class="form-control" id="COMMISSION_TYPE" required
                                            name="STATUS" ng-model="model.COMMISSION_TYPE" style="width:100%">

                                        <option ng-repeat="item in CommissionType" value="{{item.COMMISSION_TYPE}}" ng-selected="item.COMMISSION_TYPE == model.COMMISSION_TYPE">{{item.COMMISSION_TYPE}}</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label for="EFFECT_START_DATE">Effect Start Date<sup>*</sup></label>
                                </div>
                                @* <div class="col-md-2">
                                   <input id="EFFECT_START_DATE" type="text" class="form-control"  required name="EFFECT_START_DATE"  ng-model="model.EFFECT_START_DATE" >

                                 </div>*@

                                <div class="col-md-2 simple-date2">
                                    <div class="input-group date">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text"><i class="fas fa-calendar"></i></span>
                                        </div>
                                        <input type="text" autocomplete="off" class="form-control" ng-model="model.EFFECT_START_DATE" ng-change="CheckENDDateValidation(model) || CheckDateValidation(model)" required value="" id="EFFECT_START_DATE">
                                    </div>
                                </div>

                                <div class="col-md-2">
                                    <label for="EFFECT_END_DATE">Effect End Date<sup>*</sup></label>
                                </div>

                                <div class="col-md-2 simple-date2">
                                    <div class="input-group date">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text"><i class="fas fa-calendar"></i></span>
                                        </div>
                                        <input type="text" autocomplete="off" class="form-control" ng-model="model.EFFECT_END_DATE" ng-change="CheckENDDateValidation(model) || CheckDateValidation(model)" required value="" id="EFFECT_END_DATE">
                                    </div>
                                </div>
                                @* <div class="col-md-2">
                                   <input id="EFFECT_END_DATE" type="text"  class="form-control"  required  name="EFFECT_END_DATE"  ng-model="model.EFFECT_END_DATE" >   
                                 </div>*@

                            </div>

                        </div>
                        <div class="col-md-12 space-bottom">
                            <div class="row">
                                <div class="col-md-2">
                                    <label for="COMMISSION_VALUE">Commission Value<sup>*</sup></label>
                                </div>
                                <div class="col-md-2">
                                    <input id="COMMISSION_VALUE" type="number" min="0" class="form-control" required name="COMMISSION_VALUE" ng-model="model.COMMISSION_VALUE">
                                    @*<input id="COMPANY_NAME" type="text" disabled class="form-control"  required   name="COMPANY_NAME"  ng-model="model.COMPANY_NAME" >*@

                                </div>
                                <div class="col-md-2">
                                    <label for="ADD_COMMISSION1">Add Commission1</label>
                                </div>
                                <div class="col-md-2">
                                    <input id="ADD_COMMISSION1" type="number" min="0" class="form-control" name="ADD_COMMISSION1" ng-model="model.ADD_COMMISSION1">

                                </div>

                                <div class="col-md-2">
                                    <label for="ADD_COMMISSION2">Add Commission2</label>
                                </div>
                                <div class="col-md-2">
                                    <input id="ADD_COMMISSION2" type="number" min="0" class="form-control" name="ADD_COMMISSION2" ng-model="model.ADD_COMMISSION2">
                                </div>
                            </div>

                        </div>

                        <div class="col-md-12 space-bottom">
                            <div class="row">
                                <div class="col-md-2">
                                    <label for="REMARKS">Remarks</label>
                                </div>
                                <div class="col-md-4">
                                    <input id="REMARKS" type="text" class="form-control"
                                           name="REMARKS" ng-model="model.REMARKS">

                                </div>

                                <div class="col-md-2">
                                    <label>Status</label>
                                </div>
                                <div class="col-md-4">

                                    @* <select class="form-control form-white input-sm" id="STATUS" ng-model="STATUS" required>
                                        <option value="Active">Active</option>
                                        <option value="Inactive">Inactive</option>
                                     </select>*@
                                    <select class="form-control" id="STATUS"
                                            name="STATUS" ng-model="model.STATUS" style="width:100%">

                                        <option ng-repeat="item in Status" value="{{item.STATUS}}" ng-selected="item.STATUS == model.STATUS">{{item.STATUS}}</option>
                                    </select>

                                </div>

                            </div>

                        </div>
                    </div>
                </fieldset>
            </form>

        </div>
    </div>

    <div class="card mb-4">

        <div class="card-body">
            <fieldset>
                <legend style="width:200px">Commission Search</legend>
                <div class="row" style="height: 57vh;">
                    <div class="col-lg-12 mb-4">
                        <div class="card" @*ng-show="model.LIST_VIEW == 'Active'"*@ style="margin: 10px">
                            <div ui-grid="gridSearch" ui-grid-exporter ui-grid-auto-fit-columns ui-grid-resize-columns ui-grid-auto-resize
                                 style="font-family: 'Open Sans', Arial, sans-serif; color: #252222 !important; height: 50vh;" class="grid">
                            </div>
                        </div>
                    </div>
                </div>
            </fieldset>

        </div>
    </div>
    @*<partial name="~/Views/Shared/_Loader.cshtml" ng-show="showloader" ></partial>*@
</div>
@section Scripts {
    <script src="~/ScriptsNg/SalesAndDistribution/CustomerCommission/Controller/CustomerCommissionCtr.js"></script>
    <script src="~/ScriptsNg/SalesAndDistribution/CustomerCommission/Service/CustomerCommissionServices.js"></script>
    <script src="~/ScriptsNg/Services/permissionProvider.js"></script>
    <script src="~/ScriptsNg/Services/gridRegistrationService.js"></script>
    <script src="~/Design/vendor/select2/dist/js/select2.min.js"></script>
    <script type="text/javascript">
           $(document).ready(function () {
               $(".select2-single").select2({
                   placeholder: "Select...."
               });

        });
    </script>
    <script>
        var CurrentDate = '@ViewBag.CurentDate';
    </script>
}