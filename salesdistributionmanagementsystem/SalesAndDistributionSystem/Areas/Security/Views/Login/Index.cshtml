@model List<SalesAndDistributionSystem.Domain.Models.TableModels.Company.Company_Info>
@{
    Layout = null;
}
<!doctype html>
<html>
<head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/jpg" href="~/design/img/logo/logo.png">
    <!-- Bootstrap CSS -->
    <link href="~/assets/css/bootstrap.min.css" rel="stylesheet" />
    <!-- FontAwesome CSS -->
    <link href="~/assets/css/all.min.css" rel="stylesheet" />
    <link href="~/assets/css/uf-style.css" rel="stylesheet" />
    <title>CDMS | LOGIN</title>
</head>
<body className='snippet-body'>
    <div class="uf-form-signin">
        <div class="text-center">
            <a href="#"><img src="~/img/square-toiletries-logo.png" alt="" width="300" style="cursor: default;"></a>
        </div>
        <form class="mt-4" method="post">
            <div class="input-group uf-input-group input-group-lg mb-3">
                <span class="input-group-text fa fa-user"></span>
                <input type="text" class="form-control" placeholder="Email address" name="Email" value="@ViewBag.UserName">
            </div>
            <div class="input-group uf-input-group input-group-lg mb-3">
                <span class="input-group-text fa fa-lock"></span>
                <input type="password" class="form-control" placeholder="Password" name="Password" value="@ViewBag.UserPass">
            </div>
            <div class="d-flex mb-3 justify-content-between">
                <div class="form-check">
                    <input type="checkbox" class="form-check-input uf-form-check-input" id="chk1" name="chk">
                    <label class="form-check-label text-white" for="exampleCheck1">Remember Me</label>
                </div>
                <a href="~/Security/Login/ForgetPassword">Forgot password?</a>
            </div>
            <div class="d-grid mb-4">
                <button type="submit" class="btn uf-btn-primary btn-lg">Login</button>
            </div>
            @if (ViewBag.errorMessage != null)
            {
                <div class="d-flex mb-3">
                    <div class="dropdown-divider m-auto w-25"></div>
                    <div class="text-nowrap text-white blink-soft h6">@ViewBag.errorMessage</div>
                    <div class="dropdown-divider m-auto w-25"></div>
                </div>
            }
            @*             <div class="uf-social-login d-flex justify-content-center">
                <a href="#" class="uf-social-ic" title="Login with Facebook"><i class="fab fa-facebook-f"></i></a>
                <a href="#" class="uf-social-ic" title="Login with Twitter"><i class="fab fa-twitter"></i></a>
                <a href="#" class="uf-social-ic" title="Login with Google"><i class="fab fa-google"></i></a>
            </div> *@
            <div class="mt-4 text-center">
                <h2 class="text-white">CDMS</h2>
            </div>
        </form>
    </div>
    <!-- JavaScript -->
    <!-- Separate Popper and Bootstrap JS -->
    <script src="~/assets/js/popper.min.js"></script>
    <script src="~/assets/js/bootstrap.min.js"></script>
</body>
</html>
