@{
    ViewData["Title"] = "Unit";
}
<link href="/css/site.css" rel="stylesheet">


<div class="container-fluid" id="container-wrapper" ng-app="ngApp" ng-controller="ngGridCtrl">
    <div class="d-sm-flex align-items-center justify-content-between mt-1">
        <h1 class="h3 mb-0 text-gray-800">@ViewData["Title"].ToString()</h1>
        <ol class="breadcrumb mb-0 pb-1">
            <li class="breadcrumb-item" ng-show="!showDiv">
                <a href="/Security/Company/Unit" class="btn btn-warning btn-icon-split btn-sm">
                    <span class="icon text-white-50">
                        <i class="fas fa-sync-alt"></i>
                    </span>
                    <span class="text">Reload</span>
                </a>
            </li>
            <li class="breadcrumb-item" ng-show="!showDiv">
                <button type="button" class="btn btn-success btn-icon-split btn-sm" ng-disabled="formMenuCategoryAdd.$invalid" ng-show="model.ADD_PERMISSION == 'Active'" ng-click="SaveData(model)" disable-button>
                    <span class="icon text-white-50">
                        <i class="fas fa-save"></i>
                    </span>
                    <span class="text">Save</span>
                </button>
            </li>
        </ol>
    </div>
    <div class="row">
        <div class="col-lg-12">
            <div class="card mb-4">
                <div class="card-body p-1">
                    <form name="formMenuCategoryAdd">
                        <fieldset>
                            <div class="ml-3 mr-3 mt-3">
                                <div class="row">
                                    <div class="col-md-2">
                                        <div class="form-group">
                                            <label> Company</label>
                                            <select class="select2-single form-control" id="COMPANY_ID" required ng-disabled="model.USER_TYPE != 'SuperAdmin'"
                                                    name="COMPANY_ID" ng-model="model.COMPANY_ID" style="width:100%">
                                                <option ng-repeat="item in CompanyData" ng-selected="item.COMPANY_ID == model.COMPANY_ID" value="{{item.COMPANY_ID}}">{{item.COMPANY_NAME}}</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-5">
                                        <div class="form-group">
                                            <label for="UNIT_NAME">Unit Name</label>
                                            <input type="text" class="form-control" autocomplete="off" required data-val="true"
                                                   name="UNIT_NAME" ng-model="model.UNIT_NAME" placeholder="Enter Unit Name">
                                        </div>
                                    </div>
                                    <div class="col-md-5">
                                        <div class="form-group">
                                            <label for="UNIT_SHORT_NAME"> Short Name</label>
                                            <input id="UNIT_SHORT_NAME" type="text" class="form-control" required
                                                   name="UNIT_SHORT_NAME" ng-model="model.UNIT_SHORT_NAME" placeholder="Enter Unit Short Name">


                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="form-group">
                                            <label> Unit Type</label>
                                            <select class="select2-single form-control" id="UNIT_TYPE" required
                                                    name="UNIT_TYPE" ng-model="model.UNIT_TYPE" style="width:100%">

                                                <option ng-repeat="item in UnitData" value="{{item.UNIT_TYPE}}">{{item.UNIT_TYPE}}</option>
                                            </select>



                                        </div>
                                    </div>
                                    <div class="col-md-5">
                                        <div class="form-group">
                                            <label for="UNIT_ADDRESS1">Unit Address 1 </label>
                                            <input id="UNIT_ADDRESS1" type="text" class="form-control" required
                                                   name="UNIT_ADDRESS1" ng-model="model.UNIT_ADDRESS1" placeholder="Enter Unit Address 1">

                                        </div>
                                    </div>
                                    <div class="col-md-5">
                                        <div class="form-group">
                                            <label for="UNIT_ADDRESS2">Unit Address 2</label>
                                            <input id="UNIT_ADDRESS2" type="text" class="form-control" required
                                                   name="UNIT_ADDRESS2" ng-model="model.UNIT_ADDRESS2" placeholder="Enter Unit Address 2">


                                        </div>
                                    </div>
                                </div>
                            </div>
                        </fieldset>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-lg-12">
            <div class="card">
                <div class="card-body p-2">
                    <fieldset>
                        <legend style="width:190px">Unit List</legend>
                        <div ng-show="model.LIST_VIEW == 'Active'">
                            <div ui-grid="gridOptionsList" ui-grid-exporter ui-grid-auto-fit-columns ui-grid-resize-columns ui-grid-auto-resize ui-grid-pinning
                                 style="color: #252222;height: 45vh " class="grid m-2">
                            </div>
                        </div>
                    </fieldset>
                </div>
            </div>
        </div>
    </div>
    <partial name="~/Views/Shared/_Loader.cshtml" ng-show="showloader"></partial>
</div>


@section Scripts {
    <script src="~/ScriptsNg/Security/Company/Controller/UnitCtr.js"></script>
    <script src="~/ScriptsNg/Security/Company/Service/CompanyService.js"></script>
    <script src="~/ScriptsNg/Services/permissionProvider.js"></script>
    <script src="~/ScriptsNg/Services/gridRegistrationService.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            $(".select2-single").select2({
                placeholder: "Select...."
            });

        });
    </script>
}


