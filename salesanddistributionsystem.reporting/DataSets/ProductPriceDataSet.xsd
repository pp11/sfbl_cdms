                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT A.PRICE_ENTRY_DATE,
          A.PRICE_EFFECT_DATE,
          A.SKU_ID,
          A.SKU_CODE,
          '' SKU_NAME,
          '' PACK_SIZE,
          B.SHIPPER_QTY,
          A.UNIT_TP,
          A.UNIT_VAT,
          A.SUPPLIMENTARY_TAX,
          A.MRP,
          A.EMPLOYEE_PRICE,
          A.SPECIAL_PRICE,
          A.GROSS_PROFIT,
          
          B.PRODUCT_TYPE_ID, 
          '' PRODUCT_TYPE_NAME,
          B.PRIMARY_PRODUCT_ID,
          '' PRIMARY_PRODUCT_NAME,
          B.BRAND_ID,
          '' BRNAD_NAME, 
          B.CATEGORY_ID, 
          '' CATEGORY_NAME,
          B.BASE_PRODUCT_ID,
          '' BASE_PRODUCT_NAME,
          B.GROUP_ID,          
          '' GROUP_NAME,
          A.COMPANY_ID,
          '' COMPANY_NAME,
          A.UNIT_ID,
          '' UNIT_NAME,
          '' Status
     FROM PRODUCT_PRICE_INFO A, PRODUCT_INFO B
    WHERE     A.COMPANY_ID = B.COMPANY_ID
          AND A.SKU_ID = B.SKU_ID
          AND TRUNC (PRICE_ENTRY_DATE) =
                 (SELECT MAX (TRUNC (PRICE_ENTRY_DATE))
                    FROM PRODUCT_PRICE_INFO
                   WHERE     COMPANY_ID = A.COMPANY_ID
                         AND UNIT_ID = A.UNIT_ID
                         AND SKU_ID = A.SKU_ID
                         AND TRUNC (PRICE_EFFECT_DATE) &lt;= TRUNC (SYSDATE))
          AND B.PRODUCT_STATUS = 'Active'</CommandText>
