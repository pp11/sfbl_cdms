@model List<SalesAndDistributionSystem.Domain.Models.ViewModels.Security.ReportPermission>
@{
    int d = 0;
    ViewData["Title"] = "Receive Report";

}
@section Styles {
    <link href="/css/site.css" rel="stylesheet">
    <style>
        .ui-grid-header-cell .ui-grid-cell-contents {
            white-space: normal !important;
            text-align: center !important;
        }

        .table td, .table th {
            padding: .5rem !important;
        }

    </style>
}
<div class="container-fluid" id="container-wrapper" ng-app="ngApp" ng-controller="ngGridCtrl">
    <div class="d-sm-flex align-items-center justify-content-between mt-1">
        <h1 class="h3 mb-0 text-gray-800">@ViewData["Title"].ToString()</h1>
        <ol class="breadcrumb mb-0 pb-1">
            <li class="breadcrumb-item">
                <a href="/Target/Report/TargetReport" class="btn btn-warning btn-icon-split btn-sm">
                    <span class="icon text-white-50">
                        <i class="fas fa-sync-alt"></i>
                    </span>
                    <span class="text">Reload</span>
                </a>
            </li>
            <li class="breadcrumb-item">
                <button ng-click='GetExcel()' ng-disabled="model.CSV_PERMISSION != 'Active'" type="button" class="btn btn-secondary btn-icon-split btn-sm">
                    <span class="icon text-white-50">
                        <i class="fas fa-file-excel"></i>
                    </span>
                    <span class="text">Excel Report</span>
                </button>
            </li>
            <li class="breadcrumb-item" ng-show="dotMatrixPrinterButton">
                <button ng-click='GetPreview()' ng-disabled="model.PREVIEW_PERMISSION != 'Active'" type="button" class="btn btn-warning btn-icon-split btn-sm">
                    <span class="icon text-white-50">
                        <i class="fa fa-eye" aria-hidden="true"></i>
                    </span>
                    <span class="text">Preview Report</span>
                </button>
            </li>
            <li class="breadcrumb-item" ng-show="dotMatrixPrinterButton">
                <button ng-click='GetDotPreview()' ng-disabled="model.PREVIEW_PERMISSION != 'Active'" type="button" class="btn btn-warning btn-icon-split btn-sm">
                    <span class="icon text-white-50">
                        <i class="fa fa-eye" aria-hidden="true"></i>
                    </span>
                    <span class="text">Dot Printer Preview Report</span>
                </button>
            </li>
            <li class="breadcrumb-item" ng-show="dotMatrixPrinterButton">
                <button ng-click='GetDotPdfView()' ng-disabled="model.PDF_PERMISSION != 'Active'" type="button" class="btn btn-success btn-icon-split btn-sm">
                    <span class="icon text-white-50">
                        <i class="far fa-file-pdf"></i>
                    </span>
                    <span class="text">Dot Printer PDF Report</span>
                </button>
            </li>
            <li class="breadcrumb-item">
                <button ng-click='GetPdfView()' ng-disabled="model.PDF_PERMISSION != 'Active'" type="button" class="btn btn-success btn-icon-split btn-sm">
                    <span class="icon text-white-50">
                        <i class="far fa-file-pdf"></i>
                    </span>
                    <span class="text">PDF Report</span>
                </button>
            </li>
        </ol>
    </div>
    <!-- row -->
    <div class="row">
        <div class="col-lg-12">
            <div class="card mb-1">
                <div class="card-body p-1">
                    <form name="formProductAdd">
                        <fieldset>
                            <div class="ml-3 mr-3 mt-3">
                                <div class="row">
                                    <div class="col-lg-6">
                                        <div class="card">
                                            <div class="table-responsive font-weight-bold">
                                                <table class="table align-items-center table-flush">
                                                    <thead class="thead-light">
                                                        <tr>
                                                            <th>SL</th>
                                                            <th>Select</th>
                                                            <th>Report Name</th>
                                                            <th>Report Id</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var item in Model)
                                                        {
                                                            <tr>
                                                                <td>@(++d)</td>
                                                                <td><input class="form-control checkbox-inline" name="selection[@d]" id="selection[@d]" ng-click="LoadReportParamters(@item.REPORT_ID,@d)" type="checkbox" value="true" height="10" style="height:20px !important" /></td>
                                                                <td>@item.REPORT_NAME <input id="ReportIdEncrypt[@d]" name="ReportIdEncrypt" value="@item.ReportIdEncrypt" hidden /></td>
                                                                <td>@item.REPORT_ID</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                            <div class="card-footer"></div>
                                        </div>
                                    </div>
                                    <div class="col-xl-6 col-lg-6 ">
                                        <div class="card">
                                            <div class="card-header py-3 bg-secondary d-flex flex-row align-items-center justify-content-between">
                                                <h6 class="m-0 font-weight-bold text-light">Parameter</h6>
                                            </div>
                                            <div>
                                                <div class="customer-message align-items-center m-1">
                                                    <div class="col-md-12 space-bottom" id="company_unit_param" style="display:block">
                                                        <div class="row">
                                                            <div class="col-md-4">
                                                                <label for="UNIT_ID">Unit</label>
                                                            </div>
                                                            <div class="col-md-8">
                                                                <select class="select2-single form-control" id="UNIT_ID" ng-disabled="model.USER_TYPE != 'SuperAdmin'"
                                                                        name="UNIT_ID" ng-model="model.UNIT_ID" ng-change="selectUnitName()" style="width:100%">

                                                                    <option ng-repeat="item in CompanyUnit" value="{{item.UNIT_ID}}" ng-selected="item.UNIT_ID == model.UNIT_ID">{{item.UNIT_NAME}}</option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-12 space-bottom" id="date_from_param" style="display:block">
                                                        <div class="row">
                                                            <div class="col-md-4">
                                                                <label for="DATE_FROM">From Date</label>
                                                            </div>
                                                            <div class="col-md-8 simple-date2">

                                                                <div class="input-group date">
                                                                    <div class="input-group-prepend">
                                                                        <span class="input-group-text"><i class="fas fa-calendar"></i></span>
                                                                    </div>
                                                                    <input type="text" ng-change="LoadData()" class="form-control" ng-model="model.DATE_FROM">
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-12 space-bottom" id="date_to_param" style="display:block">
                                                        <div class="row">
                                                            <div class="col-md-4">
                                                                <label for="DATE_TO">To Date</label>
                                                            </div>
                                                            <div class="col-md-8 simple-date2">
                                                                <div class="input-group date">
                                                                    <div class="input-group-prepend">
                                                                        <span class="input-group-text"><i class="fas fa-calendar"></i></span>
                                                                    </div>
                                                                    <input type="text" ng-change="LoadData()" class="form-control" ng-model="model.DATE_TO">
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-12 space-bottom" style="display:none">
                                                        <div class="row">
                                                            <div class="col-md-4">
                                                                <label for="COMPANY_ID">Company</label>
                                                            </div>
                                                            <div class="col-md-8">
                                                                <select class="select2-single form-control" id="COMPANY_ID" ng-disabled="model.USER_TYPE != 'SuperAdmin'"
                                                                        name="COMPANY_ID" ng-model="model.COMPANY_ID" style="width:100%" ng-change="LoadGeneratedProductCode()">

                                                                    <option ng-repeat="item in Companies" ng-selected="item.COMPANY_ID == model.COMPANY_ID" value="{{item.COMPANY_ID}}">{{item.COMPANY_NAME}}</option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-12 space-bottom" id="transfer_note_no" style="display:none">
                                                        <div class="row">
                                                            <div class="col-md-4">
                                                                <label for="TRANSFER_NOTE_NO">Transfer Note No</label>
                                                            </div>
                                                            <div class="col-md-8">
                                                                <select class="select2-single form-control" id="TRANSFER_NOTE_NO" multiple
                                                                        name="TRANSFER_NOTE_NO" ng-model="model.TRANSFER_NOTE_NO" style="width:100%">

                                                                    <option ng-repeat="item in transferNotes" ng-selected="item.TRANSFER_NOTE_NO == model.TRANSFER_NOTE_NO" value="{{item.TRANSFER_NOTE_NO}}">{{item.TRANSFER_NOTE_NO}}</option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-12 space-bottom" id="challan_no_param" style="display:none">
                                                        <div class="row">
                                                            <div class="col-md-4">
                                                                <label for="CHALLAN_NO">Challan No</label>
                                                            </div>
                                                            <div class="col-md-8">
                                                                <select class="select2-single form-control" id="CHALLAN_NO" multiple
                                                                        name="CHALLAN_NO" ng-model="model.CHALLAN_NO" style="width:100%">

                                                                    <option ng-repeat="item in challans" ng-selected="item.CHALLAN_NO == model.CHALLAN_NO" value="{{item.CHALLAN_NO}}">{{item.CHALLAN_NO}}</option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-12 space-bottom" id="multi_products" style="display:none">
                                                        <div class="row">
                                                            <div class="col-md-4">
                                                                <label for="SKU_ID">Products</label>
                                                            </div>
                                                            <div class="col-md-8">
                                                                <select class="select2-single form-control" id="MULTI_SKU_ID" multiple
                                                                        name="SKU_ID" ng-model="model.MULTI_SKU_ID" ng-change="GetBatches()" style="width:100%">

                                                                    <option ng-repeat="item in Products" value="{{item.SKU_ID}}" ng-selected="item.SKU_ID== model.SKU_ID">{{item.SKU_CODE}} - {{item.SKU_NAME}}</option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-12 space-bottom" id="single_products" style="display:none">
                                                        <div class="row">
                                                            <div class="col-md-4">
                                                                <label for="PRIMARY_PRODUCT_ID">Products</label>
                                                            </div>
                                                            <div class="col-md-8">
                                                                <select class="select2-single form-control" id="SKU_ID"
                                                                        name="PRIMARY_PRODUCT_ID" ng-model="model.PRIMARY_PRODUCT_ID" style="width:100%">

                                                                    <option ng-repeat="item in Products" value="{{item.SKU_CODE}}" ng-selected="item.PRIMARY_PRODUCT_ID== model.PRIMARY_PRODUCT_ID">{{item.SKU_CODE}} - {{item.SKU_NAME}}</option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-12 space-bottom" id="base_product_batch_param" style="display:none">
                                                        <div class="row">
                                                            <div class="col-md-4">
                                                                <label for="Batch_ID">Batch</label>
                                                            </div>
                                                            <div class="col-md-8">
                                                                <select class="select2-single form-control" id="MULTI_BATCH_NO" multiple
                                                                        name="MULTI_BATCH_NO" ng-model="model.MULTI_BATCH_NO" style="width:100%">

                                                                    <option ng-repeat="item in Batches" value="{{item.BATCH_NO}}" ng-selected="item.BATCH_NO == model.BATCH_NO">{{item.BATCH_NO}}</option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-12 space-bottom" id="item_id_param" style="display:none">
                                                        <div class="row">
                                                            <div class="col-md-4">
                                                                <label for="ITEM_ID">Gift Item</label>
                                                            </div>
                                                            <div class="col-md-8">
                                                                <select class="select2-single form-control" id="ITEM_ID" multiple
                                                                        name="ITEM_ID" ng-model="model.GIFT_ITEM_ID" style="width:100%">

                                                                    <option ng-repeat="item in items" ng-selected="item.GIFT_ITEM_ID == model.GIFT_ITEM_ID" value="{{item.GIFT_ITEM_ID}}">{{item.GIFT_ITEM_NAME}}</option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-12 space-bottom" id="Color_no_param" style="display:none">
                                                        <div class="row">
                                                            <div class="col-md-4">
                                                                <label for="MST_ID">Color</label>
                                                            </div>
                                                            <div class="col-md-8">
                                                                <select class="form-control" name="ReportColor" ng-model="model.ReportColor" id="ReportColor" style="width:100%">
                                                                    <option value="color">Colorful</option>
                                                                    <option value="Grayscale">Grayscale</option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </fieldset>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <!-- Row -->
    @*<partial name="~/Views/Shared/_Loader.cshtml" ng-show="showloader"></partial>*@
</div>

@section Scripts {
    <script src="~/ScriptsNg/Inventory/Report/Controller/ReceiveReportCtr.js?v=71"></script>
    <script src="~/ScriptsNg/Inventory/Report/Service/ReceiveReportService.js"></script>
    <script src="~/ScriptsNg/Services/permissionProvider.js"></script>
    <script src="~/Design/vendor/select2/dist/js/select2.min.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            $(".select2-single").select2({
            });
        });
    </script>
}