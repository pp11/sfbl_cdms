@{
    ViewData["Title"] = "User";
}
<link href="/css/site.css" rel="stylesheet">
<div class="container-fluid" id="container-wrapper" ng-app="ngApp" ng-controller="ngGridCtrl">
    <div class="d-sm-flex align-items-center justify-content-between mt-1">
        <h4 class="h3 mb-0 text-gray-600">@ViewData["Title"].ToString()</h4>
        <ol class="breadcrumb mb-0 pb-1">
            <li class="breadcrumb-item" ng-show="!showDiv">
                <a href="/Security/User/index" class="btn btn-warning btn-icon-split btn-sm">
                    <span class="icon text-white-50">
                        <i class="fas fa-sync-alt"></i>
                    </span>
                    <span class="text">Reload</span>
                </a>
            </li>
            <li class="breadcrumb-item" ng-show="!showDiv">
                <button type="button" class="btn btn-success btn-icon-split btn-sm" ng-disabled="formMenuCategoryAdd.$invalid || model.EMPLOYEE_ID <=0" ng-show="model.ADD_PERMISSION == 'Active'" ng-click="SaveData(model)">
                    <span class="icon text-white-50">
                        <i class="fas fa-save"></i>
                    </span>
                    <span class="text">Save</span>
                </button>
            </li>
        </ol>
    </div>
    <div class="row">
        <div class="col-lg-12">
            <div class="card mb-4">
                <div class="card-body p-1">
                    <form name="formMenuCategoryAdd">
                        <fieldset>
                            <div class="ml-3 mr-3 mt-3">
                                <div class="row">
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label for="EMPLOYEE_ID">Employee</label>
                                            <select class="form-control select2-single" name="EMPLOYEE_ID" id="EMPLOYEE_ID" ng-model="model.EMPLOYEE_ID" ng-change="onemployeeSelect(model.EMPLOYEE_ID)"
                                                    ng-options="option.EMPLOYEE_ID as (option.EMPLOYEE_NAME + '(' + option.EMPLOYEE_ID + ')') for option in EmployeeData" required>
                                            </select>

                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label for="EMAIL">Email</label>
                                            <input id="EMAIL" type="email" class="form-control" name="EMAIL" ng-model="model.EMAIL" placeholder="Enter User Login Email" required>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-2">
                                        <div class="form-group">
                                            <label for="UNIT_ID">Unit</label>
                                            <select class="form-control" name="UNIT_ID" id="UNIT_ID" ng-model="model.UNIT_ID"
                                                    ng-options="option.UNIT_ID as option.UNIT_NAME for option in CompanyUnits" required>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="form-group">
                                            <label for="USER_TYPE">User Type</label>
                                            <select class="form-control" name="USER_TYPE" id="USER_TYPE" ng-model="model.USER_TYPE"
                                                    ng-options="option.Type as option.Type for option in UserTypeData" required>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="form-group">
                                            <label for="STATUS">Status</label>
                                            <select class="form-control" name="STATUS" id="STATUS" ng-model="model.STATUS"
                                                    ng-options="option.VALUE as option.NAME for option in EmployeeStatus" required>
                                            </select>
                                        </div>
                                    </div>
                                    
                                </div>
                            </div>
                        </fieldset>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-lg-12">
            <div class="card">
                <div class="card-body p-2">
                    <fieldset>
                        <legend style="width:190px">Employee List</legend>
                        <div ng-show="model.LIST_VIEW == 'Active'">
                            <div ui-grid="gridOptionsList" ui-grid-exporter ui-grid-auto-fit-columns ui-grid-resize-columns ui-grid-auto-resize ui-grid-pinning
                                 style="color: #252222;height: 59vh " class="grid m-2">
                            </div>
                        </div>
                    </fieldset>
                </div>
            </div>
        </div>
    </div>
    <partial name="~/Views/Shared/_Loader.cshtml" ng-show="showloader"></partial>
</div>
@section Scripts {
    <script src="~/ScriptsNg/Security/User/Controller/UserCtr.js"></script>
    <script src="~/ScriptsNg/Security/User/Service/UserServices.js"></script>
    <script src="~/ScriptsNg/Security/Company/Service/CompanyService.js"></script>
    <script src="~/ScriptsNg/Services/permissionProvider.js"></script>
    <script src="~/ScriptsNg/Services/gridRegistrationService.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            $(".select2-single").select2({
                placeholder: "Select...."
            });

        });
    </script>
}
