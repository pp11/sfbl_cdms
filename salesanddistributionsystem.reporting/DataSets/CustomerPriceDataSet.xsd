         FN_PACK_SIZE(D.COMPANY_ID, D.SKU_ID) PACK_SIZE,
         D.SKU_PRICE,
         D.STATUS AS EXPR1,
         C.COMPANY_NAME,
         U.UNIT_NAME,
         R.CUSTOMER_NAME,
         '' CUSTOMER_TYPE_NAME
    FROM CUSTOMER_SKU_PRICE_MST M,
         CUSTOMER_INFO R,
         CUSTOMER_SKU_PRICE_DTL D,
         PRODUCT_INFO P,
         STL_ERP_SCS.COMPANY_INFO C,
         STL_ERP_SCS.COMPANY_INFO U
   WHERE R.CUSTOMER_ID = M.CUSTOMER_ID
         AND D.CUSTOMER_PRICE_MSTID = M.CUSTOMER_PRICE_MSTID
         AND P.SKU_ID = D.SKU_ID
         AND C.COMPANY_ID = M.COMPANY_ID
         AND C.UNIT_ID = M.UNIT_ID
         AND U.COMPANY_ID = M.COMPANY_ID
   ORDER BY M.CUSTOMER_PRICE_MSTID, D.CUSTOMER_PRICE_DTLID</CommandText>
