@{
    ViewData["Title"] = "SKU Wise Loading Charge";
}
<link href="/css/site.css" rel="stylesheet">
<link href="/Design/vendor/select2/dist/css/select2.min.css" rel="stylesheet" type="text/css">


<div class="container-fluid" id="container-wrapper" ng-app="ngApp" ng-controller="ngGridCtrl">
    <div class="d-sm-flex align-items-center justify-content-between mb-4 sm-breadcrumb">
        <h4 class="h3 mb-0 text-gray-600">
            @ViewData["Title"].ToString()
        </h4>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><button class="btn  btn-danger mb-1" ng-click="ClearForm()">Reset</button></li>
            <li class="breadcrumb-item"><button type="button" style="width: 100px;color:white;cursor:pointer" pe="button" ng-disabled="formMenuCategoryAdd.$invalid" name="btnSubmit" class="btn  btn-success mb-1" ng-click="SaveData(model)">Save</button></li>


        </ol>
    </div>


    <div class="card mb-4">

        <div class="card-body">

            <form name="formMenuCategoryAdd">
                <fieldset>
                    <legend style="width:250px">SKU Loading Charge Entry</legend>

                    <div class="row" style="margin:20px">

                        <div class="col-md-12 space-bottom">
                            <div class="row">
                                <div class="col-md-2">
                                    <label for="LOADING_CHARGE_ID">Loading Charge Id</label>
                                </div>
                                <div class="col-md-2">
                                    <input id="LOADING_CHARGE_ID" disabled type="number" class="form-control" name="LOADING_CHARGE_ID" ng-model="model.LOADING_CHARGE_ID">
                                    @*<input id="COMPANY_NAME" type="text" disabled class="form-control"  required   name="COMPANY_NAME"  ng-model="model.COMPANY_NAME" >*@

                                </div>
                                <div class="col-md-2">
                                    <label for="COMPANY_ID">Company</label>
                                </div>
                                <div class="col-md-2">
                                    <input id="COMPANY_ID" type="text" hidden class="form-control" required name="COMPANY_ID" ng-model="model.COMPANY_ID">
                                    <input id="COMPANY_NAME" type="text" disabled class="form-control" required name="COMPANY_NAME" ng-model="model.COMPANY_NAME">
                                </div>

                                <div class="col-md-2">
                                    <label for="ENTRY_DATE">Entry Date</label>
                                </div>
                                <div class="col-md-2">
                                    <input id="ENTRY_DATE" disabled type="text" class="form-control" required name="ENTRY_DATE" ng-model="model.ENTRY_DATE">
                                </div>
                            </div>
                        </div>
                        <div class="col-md-12 space-bottom">
                            <div class="row">
                                <div class="col-md-2">
                                    <label for="SKU_NAME">SKU Name</label>
                                </div>
                                <div class="col-md-4">

                                    <select class="select2-single-Product form-control" id="SKU_ID" ng-change="changeProduct()" required
                                            name="SKU_ID" ng-model="model.SKU_ID" style="width:100%">

                                        <option ng-repeat="item in Products | orderBy : 'SKU_NAME'" value="{{item.SKU_ID}}" ng-selected="item.SKU_ID == model.SKU_ID">{{item.SKU_NAME}} -- {{item.SKU_CODE}} -- {{item.PACK_SIZE}}</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    @*<input id="CUSTOMER_ID" hidden type="text"  class="form-control"  required  name="CUSTOMER_ID"  ng-model="model.CUSTOMER_ID" >   *@
                                    <input id="SKU_CODE" disabled type="text" class="form-control" required name="SKU_CODE" ng-model="model.SKU_CODE">
                                </div>
                                <div class="col-md-2">
                                    <label for="SKU_CODE">Pack Size</label>
                                </div>
                                <div class="col-md-2">
                                    @*<input id="CUSTOMER_ID" hidden type="text"  class="form-control"  required  name="CUSTOMER_ID"  ng-model="model.CUSTOMER_ID" >   *@
                                    <input id="PACK_SIZE" disabled type="text" class="form-control" required name="PACK_SIZE" ng-model="model.PACK_SIZE">
                                </div>

                            </div>

                        </div>

                        <div class="col-md-12 space-bottom">
                            <div class="row">
                                <div class="col-md-2">
                                    <label for="EFFECT_START_DATE">Effect Start Date</label>
                                </div>
                                <div class="col-md-2 simple-date2">
                                    <div class="input-group date">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text"><i class="fas fa-calendar"></i></span>
                                        </div>
                                        <input type="text" autocomplete="off" class="form-control" ng-model="model.EFFECT_START_DATE" ng-change="CheckENDDateValidation(model) || CheckDateValidation(model)" required value="" id="oneYearView">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label for="EFFECT_END_DATE">Effect End Date</label>
                                </div>

                                <div class="col-md-2 simple-date2">
                                    <div class="input-group date">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text"><i class="fas fa-calendar"></i></span>
                                        </div>
                                        <input type="text" autocomplete="off" class="form-control" ng-model="model.EFFECT_END_DATE" ng-change="CheckENDDateValidation(model) || CheckDateValidation(model)" required value="" id="oneYearView">
                                    </div>
                                </div>

                                <div class="col-md-2">
                                    <label>Status</label>
                                </div>
                                <div class="col-md-2">

                                    @* <select class="form-control form-white input-sm" id="STATUS" ng-model="STATUS" required>
                                        <option value="Active">Active</option>
                                        <option value="Inactive">Inactive</option>
                                     </select>*@
                                    <select class="form-control" id="STATUS"
                                            name="STATUS" ng-model="model.STATUS" style="width:100%">

                                        <option ng-repeat="item in Status" value="{{item.STATUS}}" ng-selected="item.STATUS == model.STATUS">{{item.STATUS}}</option>
                                    </select>

                                </div>
                            </div>

                        </div>
                        <div class="col-md-12 space-bottom">
                            <div class="row">
                                <div class="col-md-2">
                                    <label for="SHIPPER_QTY">Shipper Qty</label>
                                </div>
                                <div class="col-md-2">
                                    <input id="SHIPPER_QTY" disabled type="number" class="form-control" required name="SHIPPER_QTY" ng-model="model.SHIPPER_QTY">
                                    @*<input id="COMPANY_NAME" type="text" disabled class="form-control"  required   name="COMPANY_NAME"  ng-model="model.COMPANY_NAME" >*@

                                </div>
                                <div class="col-md-2">
                                    <label for="LOADING_CHARGE">Loading Charge</label>
                                </div>
                                <div class="col-md-2">
                                    <input id="LOADING_CHARGE" type="number" class="form-control" required name="LOADING_CHARGE" ng-model="model.LOADING_CHARGE">

                                </div>

                                <div class="col-md-2">
                                    <label for="REMARKS">Remarks</label>
                                </div>
                                <div class="col-md-2">
                                    <input id="REMARKS" type="text" class="form-control"
                                           name="REMARKS" ng-model="model.REMARKS">

                                </div>
                            </div>

                        </div>

                    </div>
                </fieldset>
            </form>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <fieldset>
                <legend style="width:200px">Search Data</legend>
                <div class="row" style="height: 57vh;">
                    <div class="col-lg-12 mb-4">
                        <div class="card" @*ng-show="model.LIST_VIEW == 'Active'"*@ style="margin: 10px">
                            <div ui-grid="gridSearch" ui-grid-exporter ui-grid-auto-fit-columns ui-grid-resize-columns ui-grid-auto-resize
                                 style="font-family: 'Open Sans', Arial, sans-serif; color: #252222 !important; height: 50vh;" class="grid">
                            </div>
                        </div>
                    </div>
                </div>
            </fieldset>

        </div>
    </div>
    @*<partial name="~/Views/Shared/_Loader.cshtml" ng-show="showloader" ></partial>*@
</div>
@section Scripts {
    <script src="~/ScriptsNg/SalesAndDistribution/SkuLoadingCharge/Controller/SkuLoadingChargeCtr.js"></script>
    <script src="~/ScriptsNg/SalesAndDistribution/SkuLoadingCharge/Service/SkuLoadingChargeServices.js"></script>
    <script src="~/ScriptsNg/Services/permissionProvider.js"></script>
    <script src="~/ScriptsNg/Services/gridRegistrationService.js"></script>
    <script src="~/Design/vendor/select2/dist/js/select2.min.js"></script>
    <script type="text/javascript">
           $(document).ready(function () {
               $(".select2-single").select2({
                   placeholder: "Select...."
               });

        });
    </script>
    <script>
        var CurrentDate = '@ViewBag.CurentDate';
    </script>
}