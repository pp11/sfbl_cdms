                    <CommandText>select '' SL,CR.UNIT_NAME as REQUISITION_UNIT_ID,M.REMARKS MASTER_REMARKS, CI.UNIT_NAME as ISSUE_UNIT_ID, M.REQUISITION_NO,M.REQUISITION_DATE,I.SKU_CODE,I.PACK_SIZE, I.SKU_NAME,  D.SKU_ID, D.UNIT_TP, M.ISSUE_NO,M.ISSUE_DATE ,D.REQUISITION_QTY, D.REQUISITIO_AMOUNT,D.ISSUE_QTY, D.ISSUE_AMOUNT, D.REMARKS 
