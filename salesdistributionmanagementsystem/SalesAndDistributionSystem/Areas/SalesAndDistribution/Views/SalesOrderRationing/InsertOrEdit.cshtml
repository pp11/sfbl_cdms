@{
    ViewData["Title"] = "Sales Order";

}
<link href="/css/site.css" rel="stylesheet">
<link href="/Design/vendor/select2/dist/css/select2.min.css" rel="stylesheet" type="text/css">
<style>
    .back_color {
        background-color: #c9c9c9;
    }

    .table-fixed-column-outter {
        position: relative;
        margin: 1rem auto;
        max-width: 95%;
    }

    .table-fixed-column-inner {
        overflow-x: scroll;
        overflow-y: visible;
        margin-left: 350px;
    }

    .sp_table.table-fixed-column {
        table-layout: fixed;
        width: 100%;
    }

    .sp_table td,
    .sp_table th {
        width: 120px;
    }

        .sp_table th:first-child,
        .sp_table tr td:first-child {
            position: absolute;
            left: 0;
            width: 120px;
            height: -webkit-fill-available;
        }
</style>

<div class="container-fluid" id="container-wrapper" ng-app="ngApp" ng-controller="ngGridCtrl">
    <div class="d-sm-flex align-items-center justify-content-between mb-4 sm-breadcrumb">
        <h4 class="h3 mb-0 text-gray-600">
            @ViewData["Title"].ToString()
        </h4>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><button class="btn  bg-primary mb-1" style="color:white" data-toggle="modal" data-target="#exampleModalScrollable" ng-click="LoadOrderRationableSKUs()">Show Filter</button></li>
            <li class="breadcrumb-item"><a class="btn  btn-primary mb-1" href="/SalesAndDistribution/SalesOrder/List">Search</a></li>
            <li class="breadcrumb-item"><a class="btn  btn-danger mb-1" href="/SalesAndDistribution/SalesOrderRationing/InsertOrEdit">Reset</a></li>
            <li class="breadcrumb-item"><button class="btn  btn-success mb-1" ng-click="SaveData()">Submit</button></li>
        </ol>
    </div>
    <div class="card mb-4">
        <div class="card-body">
            <form name="formMenuCategoryAdd">
                <fieldset>
                    <legend style="width:220px">Sales Order Entry</legend>
                    <div class="row" style="">
                        <div class="col-md-12 space-bottom">
                            <div ng-hide="Order_SKU_Data.length>0"><h1>No Data Loaded For Rationing</h1></div>
                            <div class="table-fixed-column-outter" ng-show="Order_SKU_Data.length>0">
                                <div class="table-fixed-column-inner">
                                    <table class="sp_table table table-bordered">
                                        <thead>
                                            @* <tr> <th style="width:200px"></th> <th style="width:200px" ng-repeat="item in Customer_Order">{{item.CUSTOMER_NAME}} | {{item.CUSTOMER_CODE}}</th> </tr>*@
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <th style="width:200px;border:none"></th>
                                                <th style="width:200px; position:sticky; top:0;" ng-repeat="item in Mst_Order">Customer:{{item.CUSTOMER_NAME}} | Code: {{item.CUSTOMER_CODE}} | Order No: {{item.ORDER_NO}} | Date: {{item.ORDER_DATE}} </th>
                                                <th style="width:200px;border:none"><b>Total</b></th>
                                            </tr>
                                            <tr>
                                                <th style="width:200px;border:none"></th>
                                                <th style="width:200px" ng-repeat="item in Mst_Order">
                                                    <table>
                                                        <tr style="background-color:#c3c3c3">
                                                            <td style="display:none"></td>
                                                            <td>Stock Qty</td>
                                                            <td>Order Qty</td>
                                                            <td>Sgst Qty</td>
                                                            <td>Revised Qty</td>
                                                        </tr>
                                                    </table>
                                                </th>
                                                <!--Total Count-->
                                                <th style="width:200px">
                                                    <table>
                                                        <tr style="background-color:#c3c3c3">
                                                            <td style="display:none"></td>
                                                            <td>Stock Qty</td>
                                                            <td>Order Qty</td>
                                                            <td>Sgst Qty</td>
                                                            <td>Revised Qty</td>
                                                        </tr>
                                                    </table>
                                                </th>
                                            </tr>
                                            <tr ng-repeat="item in Ratioanable_Rows ">
                                                <!--Left Column-->
                                                <td style="width:350px;">{{item.SKU_NAME}} | {{item.SKU_CODE}} </td>
                                                <td ng-repeat="item_row in item.row_data ">
                                                    <table style="table-layout: fixed; width: 100%;">
                                                        <tr ng-class="{back_color: item_row.Active}">
                                                            <td style="display:none"></td>
                                                            <td style="width:25%;">{{item_row.STOCK_QTY}}</td>
                                                            <td style="width:25%;">{{item_row.ORDER_QTY}}</td>
                                                            <td style="width:20%;">{{item_row.SUGGESTED_LIFTING}}</td>
                                                            <td style="width:30%;"><input id="{{item_row.ORDER_NO + '_' + item.SKU_ID }}" ng-disabled="item_row.Active" name="{{item_row.ORDER_NO + '_' + item.SKU_ID }}" value="" style="width:100%" class="{{$parent.$index}}" @*ng-model="item_row.REVISED_QTY"*@ ng-keyup="Calculate($index, $parent.$index)" /></td>
                                                        </tr>
                                                    </table>
                                                </td>
                                                <!--Total Count-->
                                                <td>
                                                    <table>
                                                        <tr ng-class="{back_color: item_row.Active}">
                                                            <td style="display:none"></td>
                                                            <td>{{totalStock(item.row_data)}}</td>
                                                            <td>{{totalOrder(item.row_data)}}</td>
                                                            <td>0</td>
                                                            <td><input class="{{$parent.$index}}" id="{{$parent.$index+$index}}" value="" style="width:50px" readonly /></td>
                                                        </tr>
                                                    </table>
                                                </td>
                                            </tr>
                                            <tr>
                                                <th style="width:200px;border:none"></th>
                                                <th style="width:200px" ng-repeat="item in Mst_Order">
                                                    <span>Net Order Amount: {{item.NET_ORDER_AMOUNT}} | Adjustment Amount: {{item.ADJUSTMENT_AMOUNT}}</span>
                                                    <hr />
                                                    <div class="row">
                                                        <div class="col-md-6 ">
                                                            <div class="row">
                                                                <div class="col-md-5">
                                                                    <label for="ADJUSTMENT_ID">Adjust. Name</label>
                                                                </div>
                                                                <div class="col-md-7">
                                                                    <select class="form-control" id="ADJUSTMENT_TYPE_{{item.ORDER_NO}}" required
                                                                            name="ADJUSTMENT_ID" ng-model="ADJUSTMENT_ID" style="width:100%">
                                                                        <option ng-repeat="item in Adjustments" value="{{item.ADJUSTMENT_ID}}" ng-selected="item.ADJUSTMENT_ID == model.ADJUSTMENT_ID">{{item.ADJUSTMENT_NAME}}</option>
                                                                    </select>

                                                                </div>
                                                            </div>

                                                        </div>
                                                        <div class="col-md-6 ">
                                                            <div class="row">
                                                                <div class="col-md-4">
                                                                    <label for="ADJUSTMENT_AMOUNT">Adjust. Amount </label>
                                                                </div>
                                                                <div class="col-md-8">
                                                                    <input id="ADJUSTMENT_AMOUNT_{{item.ORDER_NO}}" type="number" class="form-control" min="0" required
                                                                           name="ADJUSTMENT_AMOUNT">

                                                                </div>
                                                            </div>

                                                        </div>
                                                    </div>
                                                </th>

                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </fieldset>
                <div class="modal fade" id="exampleModalScrollable" tabindex="-1" role="dialog"
                     aria-labelledby="exampleModalScrollableTitle" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-scrollable" role="document" style="max-width:1200px;">
                        <div class="modal-content" style="height:250px !important;">
                            <div class="modal-header">
                                <h5 class="modal-title" id="exampleModalScrollableTitle">Rationable Order SKU Filter</h5>
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                            <div class="modal-body" ng-show="model.LIST_VIEW == 'Active'">
                                <div class="card">
                                    <div class="row" style="margin:10px">
                                        <div class="col-md-4 space-bottom" id="date_from_param">
                                            <div class="row">
                                                <div class="col-md-4">
                                                    <label for="DATE_FROM">From Date</label>
                                                </div>
                                                <div class="col-md-8 simple-date2">

                                                    <div class="input-group date">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text"><i class="fas fa-calendar"></i></span>
                                                        </div>
                                                        <input type="text" ng-change="LoadReportParamters" class="form-control" ng-model="model.DATE_FROM">
                                                    </div>
                                                </div>

                                            </div>

                                        </div>

                                        <div class="col-md-4 space-bottom" id="date_to_param">
                                            <div class="row">
                                                <div class="col-md-4">
                                                    <label for="DATE_TO">To Date</label>
                                                </div>
                                                <div class="col-md-8 simple-date2">
                                                    <div class="input-group date">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text"><i class="fas fa-calendar"></i></span>
                                                        </div>
                                                        <input type="text" ng-change="LoadReportParamters" class="form-control" ng-model="model.DATE_TO">
                                                    </div>
                                                </div>
                                            </div>

                                        </div>
                                        <div class="col-md-4 space-bottom" id="date_to_param">
                                            <div class="row">
                                                <div class="col-md-4">
                                                </div>
                                                <div class="col-md-4">

                                                    <button class="btn  bg-success mb-1" style="color:white;width:100%" data-toggle="modal" data-target="#exampleModalScrollable" ng-click="LoadRationableData()">Show Filter</button>

                                                </div>
                                                <div class="col-md-4">

                                                    <button class="btn  btn-danger mb-1" style="color:white;width:100%" ng-click="ClearForm()">Reset</button>

                                                </div>

                                            </div>

                                        </div>
                                        <div class="col-md-4 space-bottom" id="company_divition_param" style="display:block">
                                            <div class="row">
                                                <div class="col-md-4">
                                                    <label for="DIVISION_ID">Division</label>
                                                </div>
                                                <div class="col-md-8">
                                                    <select class="select2-single form-control" id="DIVISION_ID"
                                                            name="DIVISION" ng-model="model.DIVISION_ID" style="width:100%" ng-change="DivisionChange()">
                                                        <option ng-repeat="item in Divisions | orderBy:'DIVISION_NAME'" value="{{item.DIVISION_ID}}">{{item.DIVISION_NAME}}</option>
                                                    </select>
                                                </div>
                                            </div>

                                        </div>
                                        <div class="col-md-4 space-bottom" id="company_region_param" style="display:block">
                                            <div class="row">
                                                <div class="col-md-4">
                                                    <label for="REGION_ID">Region</label>
                                                </div>
                                                <div class="col-md-8">
                                                    <select class="select2-single form-control" id="REGION_ID"
                                                            name="REGION_ID" ng-model="model.REGION_ID" style="width:100%" ng-change="RegionChange()">
                                                        <option ng-repeat="item in Regions | orderBy:'REGION_NAME'" value="{{item.REGION_ID}}" ng-selected="item.REGION_ID == model.REGION_ID">{{item.REGION_NAME}}</option>
                                                    </select>
                                                </div>
                                            </div>

                                        </div>
                                        <div class="col-md-4 space-bottom" id="company_area_param" style="display:block">
                                            <div class="row">
                                                <div class="col-md-4">
                                                    <label for="AREA_ID">Area</label>
                                                </div>
                                                <div class="col-md-8">
                                                    <select class="select2-single form-control" id="AREA_ID"
                                                            name="AREA_ID" ng-model="model.AREA_ID" style="width:100%" ng-change="AreaChange()">
                                                        <option ng-repeat="item in Areas | orderBy:'AREA_NAME'" value="{{item.AREA_ID}}" ng-selected="item.AREA_ID == model.AREA_ID">{{item.AREA_NAME}}</option>
                                                    </select>
                                                </div>
                                            </div>

                                        </div>
                                        <div class="col-md-4 space-bottom" id="company_Territory_param" style="display:block">
                                            <div class="row">
                                                <div class="col-md-4">
                                                    <label for="TERRITORY_ID">Territory</label>
                                                </div>
                                                <div class="col-md-8">
                                                    <select class="select2-single form-control" id="TERRITORY_ID"
                                                            name="TERRITORY_ID" ng-model="model.TERRITORY_ID" style="width:100%" ng-change="TerritoryChange()">

                                                        <option ng-repeat="item in Territories" value="{{item.TERRITORY_ID}}" ng-selected="item.TERRITORY_ID == model.TERRITORY_ID">{{item.TERRITORY_NAME}}</option>
                                                    </select>
                                                </div>
                                            </div>

                                        </div>
                                        <div class="col-md-4 space-bottom" id="company_market_param" style="display:none">
                                            <div class="row">
                                                <div class="col-md-4">
                                                    <label for="MARKET_ID">Market</label>
                                                </div>
                                                <div class="col-md-8">
                                                    <select class="select2-single form-control" id="MARKET_ID"
                                                            name="MARKET_ID" ng-model="model.MARKET_ID" style="width:100%" ng-change="">

                                                        <option ng-repeat="item in Markets " value="{{item.MARKET_ID}}" value="{{item.MARKET_ID}}" ng-selected="item.MARKET_ID == model.MARKET_ID">{{item.MARKET_NAME}}</option>
                                                    </select>
                                                </div>
                                            </div>

                                        </div>
                                        <div class="col-md-8 space-bottom" id="company_region_param" style="display:block">
                                            <div class="row">
                                                <div class="col-md-2">
                                                    <label for="REGION_ID">Customer</label>
                                                </div>
                                                <div class="col-md-10">
                                                    <select class="select2-single form-control" id="CUSTOMER_ID"
                                                            name="CUSTOMER_ID" ng-model="model.CUSTOMER_ID" style="width:100%" ng-change="RegionChange()">
                                                        <option ng-repeat="item in GetDivitionToMarketRelations | orderBy:'CUSTOMER_NAME'" value="{{item.CUSTOMER_NAME}}" ng-selected="item.CUSTOMER_ID == model.CUSTOMER_ID">{{item.CUSTOMER_NAME}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-outline-primary" data-dismiss="modal">Close</button>
                                @*                  <button type="button" class="btn btn-primary">Save changes</button>
                                *@
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
    <partial name="~/Views/Shared/_Loader.cshtml" ng-show="showloader"></partial>
</div>
@section Scripts
{
    <script src="~/ScriptsNg/SalesAndDistribution/SalesOrderRationing/Controller/InsertOrEditCtr.js"></script>
    <script src="~/ScriptsNg/SalesAndDistribution/SalesOrderRationing/Service/InsertOrEditServices.js"></script>
    <script src="~/ScriptsNg/SalesAndDistribution/OrderAdjustment/Service/AdjustmentServices.js"></script>
    <script src="~/ScriptsNg/Services/permissionProvider.js"></script>
    <script src="~/Design/vendor/select2/dist/js/select2.min.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            $(".select2-single").select2({
                placeholder: "Select",
            });
        });
    </script>
}