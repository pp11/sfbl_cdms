@{
    ViewData["Title"] = "Depot Customer Relation Info";
}
<link href="/css/site.css" rel="stylesheet">
<link href="/Design/vendor/select2/dist/css/select2.min.css" rel="stylesheet" type="text/css">


<div class="container-fluid" id="container-wrapper" ng-app="ngApp" ng-controller="ngGridCtrl">
    <div class="d-sm-flex align-items-center justify-content-between mb-4 sm-breadcrumb">
        <h4 class="h3 mb-0 text-gray-600">
            @ViewData["Title"].ToString()
        </h4>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a class="btn  btn-primary mb-1" href="/SalesAndDistribution/DepotCustomerRelation/List">Search</a></li>
            <li class="breadcrumb-item"><button class="btn  btn-danger mb-1" ng-click="ClearForm()">Reset</button></li>
            <li class="breadcrumb-item"><button type="button" style="width: 100px;color:white;cursor:pointer" pe="button" ng-disabled="formMenuCategoryAdd.$invalid" name="btnSubmit" class="btn  btn-success mb-1" ng-click="SaveData(model)">Save</button></li>
        </ol>
    </div>


    <div class="card mb-4">
        <div class="card-body">
            <form name="formMenuCategoryAdd">
                <fieldset>
                    <legend style="width:280px">Depot Customer Relation Entry</legend>
                    <span ng-init="GetEditDataById('@Model.MST_ID_ENCRYPTED')"></span>

                    <div class="row" style="margin:20px">

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="COMPANY_ID">Company</label>
                                </div>
                                <div class="col-md-8">
                                    <input id="COMPANY_ID" type="text" disabled class="form-control" hidden name="COMPANY_ID" ng-model="model.COMPANY_ID">
                                    <input id="COMPANY_NAME" disabled type="text" class="form-control" name="COMPANY_NAME" ng-model="model.COMPANY_NAME">

                                </div>
                            </div>

                        </div>
                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="STATUS">Status</label>
                                </div>
                                <div class="col-md-8">
                                    <select class="form-control" id="STATUS"
                                            name="STATUS" ng-model="model.STATUS" style="width:100%">
                                        <option ng-repeat="item in Status" value="{{item.STATUS}}" ng-selected="item.STATUS == model.STATUS">{{item.STATUS}}</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-12 space-bottom">
                            <div class="row">
                                <div class="col-md-2">
                                    <label for="DEPOT_ID">Unit</label>
                                </div>
                                <div class="col-md-10">
                                    <select class="select2-single form-control" id="DEPOT_ID"
                                            name="DEPOT_ID" ng-model="model.DEPOT_ID" style="width:100%">
                                        <option ng-repeat="item in Unit" value="{{item.UNIT_ID}}" ng-selected="item.UNIT_ID == model.DEPOT_ID">{{item.UNIT_NAME}}</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="EFFECT_START_DATE">Start</label>
                                </div>
                                <div class="col-md-8">
                                    <div class="simple-date2">
                                        <div class="input-group date">
                                            <div class="input-group-prepend">
                                            </div>
                                            <input type="text" class="form-control" name="EFFECT_START_DATE" ng-model="model.EFFECT_START_DATE" placeholder="dd/mm/yyyy" id="EFFECT_START_DATE" readonly>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 space-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <label for="EFFECT_END_DATE">End</label>
                                </div>
                                <div class="col-md-8">
                                    <div class="simple-date2">
                                        <div class="input-group date">
                                            <div class="input-group-prepend">
                                            </div>
                                            <input type="text" class="form-control" name="EFFECT_END_DATE" ng-model="model.EFFECT_END_DATE" placeholder="dd/mm/yyyy" id="EFFECT_END_DATE" readonly>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-12 space-bottom">
                            <div class="row">
                                <div class="col-md-2">
                                    <label for="REMARKS">Remarks</label>
                                </div>
                                <div class="col-md-10">
                                    <input id="REMARKS" type="text" class="form-control" name="REMARKS" ng-model="model.REMARKS">
                                </div>
                            </div>
                        </div>
                    </div>
                </fieldset>
            </form>


        </div>



    </div>
    <div class="card mb-4">

        <div class="card-body">

            <fieldset>
                <legend style="width:300px">Depot Customer Relation List</legend>
                <div class="row" style="height: 57vh;">
                    <div class="col-lg-12 mb-4">
                        <div class="card" style="margin: 10px">
                            <div ui-grid="gridOptionsList" ui-grid-exporter ui-grid-auto-fit-columns ui-grid-resize-columns ui-grid-auto-resize
                                 style="font-family: 'Open Sans', Arial, sans-serif; color: #252222 !important; height: 50vh;" class="grid">
                            </div>
                        </div>
                    </div>
                </div>
            </fieldset>
        </div>
    </div>
    <partial name="~/Views/Shared/_Loader.cshtml" ng-show="showloader"></partial>
</div>
@section Scripts{
    <script src="~/ScriptsNg/SalesAndDistribution/DepotCustomerRelation/Controller/DepotCustomerRelationCtr.js"></script>
    <script src="~/ScriptsNg/SalesAndDistribution/DepotCustomerRelation/Service/DepotCustomerRelationServices.js"></script>
    <script src="~/ScriptsNg/Services/permissionProvider.js"></script>
    <script src="~/ScriptsNg/Services/gridRegistrationService.js"></script>
    <script src="~/Design/vendor/select2/dist/js/select2.min.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            $(".select2-single").select2({
                placeholder: "Select...."
            });

        });
    </script>
}