@{
    ViewData["Title"] = "Cust Wise Rem. Bonus";
}
<link href="/css/site.css" rel="stylesheet">
<link href="/Design/vendor/select2/dist/css/select2.min.css" rel="stylesheet" type="text/css">
<style>
    /* Chrome, Safari, Edge, Opera */
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    /* Firefox */
    input[type=number] {
        -moz-appearance: textfield;
    }

    .ui-grid-header-cell .ui-grid-cell-contents {
        height: 48px;
        white-space: normal;
        -ms-text-overflow: clip;
        -o-text-overflow: clip;
        text-overflow: clip;
        overflow: visible;
    }

    .ui-grid-footer-cell .ui-grid-cell-contents {
        white-space: normal;
        font-size: 11px; /* Adjust the font size value as needed */
        font-family: 'Bahnschrift Condensed', sans-serif;
    }

    .ui-grid-cell input {
        background-color: inherit;
    }

</style>
<div class="container-fluid" id="container-wrapper" ng-app="ngApp" ng-controller="ngGridCtrl">
    <div class="d-sm-flex align-items-center justify-content-between sm-breadcrumb">
        <h4 class="h3 mb-0 text-gray-600">
            @ViewData["Title"].ToString()
        </h4>
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <button type="button" class="btn btn-success btn-icon-split btn-sm" ng-show="model.ADD_PERMISSION == 'Active'" ng-click="StockSummary('Excel')">
                    <span class="icon text-white-50">
                        <i class="fa fa-list-alt"></i>
                    </span>
                    <span class="text">Summary(Excel)</span>
                </button>
            </li>
            <li class="breadcrumb-item">
                <button type="button" class="btn btn-success btn-icon-split btn-sm" ng-show="model.ADD_PERMISSION == 'Active'" ng-click="StockSummary('Pdf')">
                    <span class="icon text-white-50">
                        <i class="fa fa-list-alt"></i>
                    </span>
                    <span class="text">Summary(PDF)</span>
                </button>
            </li>
            <li class="breadcrumb-item">
                <button type="button" class="btn btn-info btn-icon-split btn-sm" ng-show="model.ADD_PERMISSION == 'Active'" ng-click="StockDetails('Excel')">
                    <span class="icon text-white-50">
                        <i class="fa fa-list-alt"></i>
                    </span>
                    <span class="text">Details(Excel)</span>
                </button>
            </li>
            <li class="breadcrumb-item">
                <button type="button" class="btn btn-info btn-icon-split btn-sm" ng-show="model.ADD_PERMISSION == 'Active'" ng-click="StockDetails('Pdf')">
                    <span class="icon text-white-50">
                        <i class="fa fa-list-alt"></i>
                    </span>
                    <span class="text">Details(PDF)</span>
                </button>
            </li>
            @* <li class="breadcrumb-item">
                <button type="button" class="btn btn-danger btn-icon-split btn-sm" ng-show="model.ADD_PERMISSION == 'Active'" ng-click="LoadData()">
                    <span class="icon text-white-50">
                        <i class="fa fa-list-alt"></i>
                    </span>
                    <span class="text">Load Report Data</span>
                </button>
            </li> *@
        </ol>
    </div>
    <div class="card m-0">
        <div class="card-body p-0">
            <fieldset>
                <div class="row">
                    <div class="col-lg-12">
                        <div class="row m-1">
                            <div class="form-group col-md-4">
                                <label for="UNIT_ID">Depot</label>
                                <select class="form-control" id="UNIT_ID" ng-disabled="model.USER_TYPE != 'SuperAdmin'" name="UNIT_ID" ng-model="model.UNIT_ID" style="width:100%" ng-change="onChangeUnit()">
                                    <option ng-repeat="item in CompanyUnit" value="{{item.UNIT_ID}}" ng-selected="item.UNIT_ID == model.UNIT_ID">{{item.UNIT_NAME}}</option>
                                </select>
                            </div>
                            <div class="col-md-2 d-none">
                                <div class="row">
                                    <div class="col-md-4">
                                        <label for="COMPANY_ID">Company</label>
                                    </div>
                                    <div class="col-md-8">
                                        <select class="select2-single form-control" id="COMPANY_ID" ng-disabled="model.USER_TYPE != 'SuperAdmin'"
                                                name="COMPANY_ID" ng-model="model.COMPANY_ID" style="width:100%" ng-change="GetRequisitionNo()">
                                            <option ng-repeat="item in Companies" ng-selected="item.COMPANY_ID == model.COMPANY_ID" value="{{item.COMPANY_ID}}">{{item.COMPANY_NAME}}</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group col-md-2">
                                <label for="YEAR">Year</label>
                                <select ng-change="onChangeYear()" class="select2-single form-control" id="YEAR" name="YEAR" ng-model="model.YEAR" style="width:100%" required>
                                    <option ng-repeat="item in years" value="{{item}}" ng-selected="item == model.YEAR">{{item}}</option>
                                </select>
                            </div>
                            <div class="form-group col-md-2">
                                <label for="MONTH_CODE">Month</label>
                                <select ng-change="onChangeMonth()" ng-disabled="!model.YEAR" class="form-control" id="MONTH_CODE" name="MONTH_CODE" ng-model="model.MONTH_CODE" style="width:100%" required>
                                    <option ng-repeat="item in months" value="{{item.Id}}" ng-selected="item.MONTH_CODE == model.MONTH_CODE">{{item.Name}}</option>
                                </select>
                            </div>
                            <div class="form-group col-md-2">
                                <label for="DATE_FROM">From Date</label>
                                <div class="simple-date2">
                                    <div class="input-group date">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text"><i class="fas fa-calendar"></i></span>
                                        </div>
                                        <input ng-change="onChangeFromDate()" ng-disabled="model.YEAR && model.MONTH_CODE" type="text" required autocomplete="off" class="form-control" ng-model="model.DATE_FROM" value="" id="DATE_FROM">
                                    </div>
                                </div>
                            </div>
                            <div class="form-group col-md-2">
                                <label for="DATE_TO">To Date</label>
                                <div class="simple-date2">
                                    <div class="input-group date">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text"><i class="fas fa-calendar"></i></span>
                                        </div>
                                        <input ng-change="onChangeFromDate()" ng-disabled="model.YEAR && model.MONTH_CODE" type="text" required autocomplete="off" class="form-control" ng-model="model.DATE_TO" value="" id="DATE_TO">
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="row">
                                    <div class="col-md-2">
                                        <label for="CUSTOMER_CODE">Customer :</label>
                                    </div>
                                    <div class="col-md-10">
                                        <select class="select2-single form-control" id="CUSTOMER_CODE" name="CUSTOMER_CODE" ng-model="model.CUSTOMER_CODE" style="width:100%" ng-change="onChangeCustomer()" required>
                                            <option ng-repeat="item in Customers" value="{{item.CUSTOMER_CODE}}" ng-selected="item.CUSTOMER_CODE == model.CUSTOMER_CODE">{{item.CUSTOMER_CODE}} | {{item.CUSTOMER_NAME}}</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <button type="button" class="btn btn-primary btn-icon-split" ng-show="model.ADD_PERMISSION == 'Active'" ng-click="LoadData()">
                                    <span class="icon text-white-50">
                                        <i class="fa fa-eye" aria-hidden="true"></i>
                                    </span>
                                    <span class="text">View  Data</span>
                                </button>
                            </div>
                            @* <div class="col-md-2">
                                <button ng-disabled="gridOptionsList.data.length<=0" type="button" class="btn btn-danger btn-icon-split" ng-show="model.ADD_PERMISSION == 'Active'" ng-click="lockLoadData()">
                                    <span class="icon text-white-50">
                                        <i class="fa fa-lock" aria-hidden="true"></i>
                                    </span>
                                    <span class="text">Lock Process Data</span>
                                </button>

                            </div> *@
                        </div>
                    </div>
                    <div class="col-lg-12">
                        <div class="card" style="margin: 5px">
                            <div ui-grid="gridOptionsList" ui-grid-exporter ui-grid-auto-fit-columns ui-grid-resize-columns ui-grid-auto-resize
                                 style="font-family: 'Open Sans', Arial, sans-serif; color: #252222 !important; height: 60vh;" class="grid">
                            </div>
                        </div>
                    </div>
                    <li class="breadcrumb-item">
                        <button type="button" class="btn btn-success btn-icon-split btn-sm" ng-show="model.ADD_PERMISSION == 'Active'" ng-click="SaveData()">
                            <span class="icon text-white-50">
                                <i class="fa fa-list-alt"></i>
                            </span>
                            <span class="text">Save</span>
                        </button>
                    </li>
                    <div class="col-lg-12">
                        <div class="card" style="margin: 5px">
                            <div ui-grid="gridCollection" ui-grid-exporter ui-grid-auto-fit-columns ui-grid-resize-columns ui-grid-auto-resize
                                 style="font-family: 'Open Sans', Arial, sans-serif; color: #252222 !important; height: 60vh;" class="grid">
                            </div>
                        </div>
                    </div>
                </div>
            </fieldset>
        </div>
    </div>
    <partial name="~/Views/Shared/_Loader.cshtml" ng-show="showloader" />
</div>

@section Scripts {
    <script src="~/ScriptsNg/Target/CustomerTarget/Controller/CustWiseRemainingBnsRptCtr.js?v=1"></script>
    <script src="~/ScriptsNg/Target/CustomerTarget/Service/CustWiseRemainingBnsRptService.js?v=1"></script>
    <script src="~/ScriptsNg/Services/permissionProvider.js"></script>
    <script src="~/ScriptsNg/Services/gridRegistrationService.js"></script>
    <script src="~/Design/vendor/select2/dist/js/select2.min.js"></script>
    <script type="text/javascript">
        $(document).ready(function() {
            $(".select2-single").select2({
                placeholder: "Select",
                allowClear: true
            });

        });
    </script>
}